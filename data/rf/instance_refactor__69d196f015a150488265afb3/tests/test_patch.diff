+# AliasRecipientName dataclass
+def test_alias_recipient_name_default_message():
+    result = AliasRecipientName(name="test@example.com")
+    assert result.name == "test@example.com"
+    assert result.message is None
+
+
+def test_alias_recipient_name_with_message():
+    result = AliasRecipientName(name="Test User <test@example.com>", message="used alias name")
+    assert result.name == "Test User <test@example.com>"
+    assert result.message == "used alias name"
