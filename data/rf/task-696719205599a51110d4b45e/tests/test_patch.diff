+import { config } from '@grafana/runtime';
+import { PromAlertingRuleState, PromRuleGroupDTO, PromRuleType } from 'app/types/unified-alerting-dto';
+
+import { mockGrafanaPromAlertingRule, mockPromAlertingRule, mockPromRecordingRule } from '../../mocks';
+import { RuleHealth } from '../../search/rulesSearchParser';
+import { Annotation } from '../../utils/constants';
+import { getDatasourceAPIUid } from '../../utils/datasource';
+import { getFilter } from '../../utils/search';
+
+import {
+  GroupFilterConfig,
+  RuleFilterConfig,
+  contactPointFilter,
+  dashboardUidFilter,
+  dataSourceNamesFilter,
+  freeFormFilter,
+  groupMatches,
+  groupNameFilter,
+  labelsFilter,
+  namespaceFilter,
+  pluginsFilter,
+  ruleHealthFilter,
+  ruleMatches,
+  ruleNameFilter,
+  ruleStateFilter,
+  ruleTypeFilter,
+} from './filterPredicates';
+
+jest.mock('../../utils/datasource');
+
+const getDatasourceAPIUidMock = jest.mocked(getDatasourceAPIUid);
+
+getDatasourceAPIUidMock.mockImplementation((ruleSourceName) => {
+  if (ruleSourceName === 'prometheus') {
+    return 'datasource-uid-1';
+  }
+  if (ruleSourceName === 'loki') {
+    return 'datasource-uid-3';
+  }
+  throw new Error(`Unknown datasource name: ${ruleSourceName}`);
+});
+
+describe('groupMatches', () => {
+  const makeGroup = (overrides: Partial<PromRuleGroupDTO> = {}): PromRuleGroupDTO => ({
+    name: 'Test Group',
+    file: 'production/alerts',
+    rules: [],
+    interval: 60,
+    ...overrides,
+  });
+
+  it('should return true when all filters in config are null', () => {
+    const config: GroupFilterConfig = { namespace: null, groupName: null };
+    expect(groupMatches(makeGroup(), getFilter({ namespace: 'anything' }), config)).toBe(true);
+  });
+
+  it('should return true when filters pass', () => {
+    const config: GroupFilterConfig = { namespace: namespaceFilter, groupName: groupNameFilter };
+    expect(groupMatches(makeGroup(), getFilter({ namespace: 'production' }), config)).toBe(true);
+  });
+
+  it('should return false when namespace filter fails', () => {
+    const config: GroupFilterConfig = { namespace: namespaceFilter, groupName: null };
+    expect(groupMatches(makeGroup(), getFilter({ namespace: 'staging' }), config)).toBe(false);
+  });
+
+  it('should return false when groupName filter fails', () => {
+    const config: GroupFilterConfig = { namespace: null, groupName: groupNameFilter };
+    expect(groupMatches(makeGroup(), getFilter({ groupName: 'nonexistent' }), config)).toBe(false);
+  });
+
+  it('should apply AND logic across both filters', () => {
+    const config: GroupFilterConfig = { namespace: namespaceFilter, groupName: groupNameFilter };
+    const group = makeGroup({ name: 'CPU Alerts', file: 'production/alerts' });
+
+    expect(groupMatches(group, getFilter({ namespace: 'production', groupName: 'cpu' }), config)).toBe(true);
+    expect(groupMatches(group, getFilter({ namespace: 'staging', groupName: 'cpu' }), config)).toBe(false);
+    expect(groupMatches(group, getFilter({ namespace: 'production', groupName: 'memory' }), config)).toBe(false);
+  });
+});
+
+describe('ruleMatches', () => {
+  const allNullConfig: RuleFilterConfig = {
+    freeFormWords: null,
+    ruleName: null,
+    ruleState: null,
+    ruleType: null,
+    dataSourceNames: null,
+    labels: null,
+    ruleHealth: null,
+    dashboardUid: null,
+    plugins: null,
+    contactPoint: null,
+  };
+
+  it('should return true when all filters in config are null', () => {
+    const rule = mockPromAlertingRule({ name: 'Test' });
+    expect(ruleMatches(rule, getFilter({ ruleName: 'nonexistent' }), allNullConfig)).toBe(true);
+  });
+
+  it('should return false when any active filter fails', () => {
+    const config: RuleFilterConfig = { ...allNullConfig, ruleName: ruleNameFilter };
+    const rule = mockPromAlertingRule({ name: 'High CPU' });
+    expect(ruleMatches(rule, getFilter({ ruleName: 'memory' }), config)).toBe(false);
+  });
+
+  it('should apply AND logic across all active filters', () => {
+    const config: RuleFilterConfig = {
+      ...allNullConfig,
+      ruleName: ruleNameFilter,
+      ruleType: ruleTypeFilter,
+    };
+    const rule = mockPromAlertingRule({ name: 'High CPU' });
+
+    expect(ruleMatches(rule, getFilter({ ruleName: 'cpu', ruleType: PromRuleType.Alerting }), config)).toBe(true);
+    expect(ruleMatches(rule, getFilter({ ruleName: 'cpu', ruleType: PromRuleType.Recording }), config)).toBe(false);
+  });
+
+  it('should skip null filters and only evaluate non-null ones', () => {
+    const config: RuleFilterConfig = {
+      ...allNullConfig,
+      ruleState: null,
+      labels: labelsFilter,
+    };
+    const rule = mockPromAlertingRule({
+      labels: { severity: 'critical' },
+      state: PromAlertingRuleState.Pending,
+      alerts: [],
+    });
+
+    expect(
+      ruleMatches(rule, getFilter({ ruleState: PromAlertingRuleState.Firing, labels: ['severity=critical'] }), config)
+    ).toBe(true);
+  });
+});
+
+describe('namespaceFilter', () => {
+  const makeGroup = (file: string): PromRuleGroupDTO => ({
+    name: 'Group',
+    file,
+    rules: [],
+    interval: 60,
+  });
+
+  it('should return true when namespace is not set', () => {
+    expect(namespaceFilter(makeGroup('production/alerts'), getFilter({}))).toBe(true);
+  });
+
+  it('should return true when namespace matches (fuzzy)', () => {
+    expect(namespaceFilter(makeGroup('production/alerts'), getFilter({ namespace: 'production' }))).toBe(true);
+  });
+
+  it('should return false when namespace does not match', () => {
+    expect(namespaceFilter(makeGroup('production/alerts'), getFilter({ namespace: 'staging' }))).toBe(false);
+  });
+
+  it('should match case-insensitively when filter state is pre-normalized', () => {
+    expect(namespaceFilter(makeGroup('Production/Alerts'), getFilter({ namespace: 'production' }))).toBe(true);
+  });
+});
+
+describe('groupNameFilter', () => {
+  const makeGroup = (name: string): PromRuleGroupDTO => ({
+    name,
+    file: 'default',
+    rules: [],
+    interval: 60,
+  });
+
+  it('should return true when groupName is not set', () => {
+    expect(groupNameFilter(makeGroup('Any Group'), getFilter({}))).toBe(true);
+  });
+
+  it('should return true when groupName matches (fuzzy)', () => {
+    expect(groupNameFilter(makeGroup('CPU Usage Alerts'), getFilter({ groupName: 'cpu' }))).toBe(true);
+  });
+
+  it('should return false when groupName does not match', () => {
+    expect(groupNameFilter(makeGroup('CPU Usage Alerts'), getFilter({ groupName: 'memory' }))).toBe(false);
+  });
+});
+
+describe('freeFormFilter', () => {
+  it('should return true when freeFormWords is empty', () => {
+    const rule = mockPromAlertingRule({ name: 'Any Rule' });
+    expect(freeFormFilter(rule, getFilter({}))).toBe(true);
