+	it( 'does not hardcode wpcom-support-chat as the fallback for bot slug resolution', () => {
+		const providerFnMatch = providerSource.match(
+			/OdieAssistantProvider[\s\S]*?\(\s*\{([\s\S]*?)\}\s*\)\s*=>\s*\{([\s\S]*?)\n\treturn/
+		);
+		if ( providerFnMatch ) {
