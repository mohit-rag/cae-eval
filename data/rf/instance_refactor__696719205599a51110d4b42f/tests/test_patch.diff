+const fs = require( 'fs' );
+const path = require( 'path' );
+
+describe( 'Help Center config', () => {
+	let configContent;
+
+	beforeAll( () => {
+		configContent = fs.readFileSync(
+			path.join( __dirname, '..', 'config.js' ),
+			'utf-8'
+		);
+	} );
+
+	it( 'includes an i18n default locale slug', () => {
+		expect( configContent ).toContain( 'i18n_default_locale_slug' );
+	} );
+} );
+
+describe( 'Help Center entry points pass bot configuration', () => {
+	let gutenbergContent;
+	let wpAdminContent;
+
+	beforeAll( () => {
+		gutenbergContent = fs.readFileSync(
+			path.join( __dirname, '..', 'help-center-gutenberg.js' ),
+			'utf-8'
+		);
+		wpAdminContent = fs.readFileSync(
+			path.join( __dirname, '..', 'help-center-wp-admin.js' ),
+			'utf-8'
+		);
+	} );
+
+	it( 'gutenberg entry point determines bot based on Commerce Garden', () => {
+		expect( gutenbergContent ).toContain( 'isCommerceGarden' );
+		expect( gutenbergContent ).toContain( 'botNameSlug' );
+	} );
+
+	it( 'gutenberg entry point passes bot configuration to HelpCenter', () => {
+		const pattern = /<HelpCenter[\s\n]/g;
+		let match;
+		while ( ( match = pattern.exec( gutenbergContent ) ) !== null ) {
+			const afterTag = gutenbergContent.substring( match.index );
+			const closingIndex = afterTag.indexOf( '/>' );
+			const usage = afterTag.substring( 0, closingIndex );
+			const hasBotProp = usage.includes( 'botNameSlug' ) || usage.includes( 'botProps' );
+			expect( hasBotProp ).toBe( true );
+		}
+	} );
+
+	it( 'wp-admin entry point determines bot based on Commerce Garden', () => {
+		expect( wpAdminContent ).toContain( 'isCommerceGarden' );
+		expect( wpAdminContent ).toContain( 'botNameSlug' );
+	} );
+
+	it( 'wp-admin entry point passes bot configuration to HelpCenter', () => {
+		const helpCenterUsages = wpAdminContent.split( '<HelpCenter' );
+		for ( let i = 1; i < helpCenterUsages.length; i++ ) {
+			const usage = helpCenterUsages[ i ].split( '/>' )[ 0 ];
+			const hasBotProp = usage.includes( 'botNameSlug' ) || usage.includes( 'botProps' );
+			expect( hasBotProp ).toBe( true );
+		}
+	} );
+} );
