+import fs from 'fs';
+import path from 'path';
+import type { HelpCenterRequiredInformation } from '../contexts/HelpCenterContext';
+
+describe( 'HelpCenterRequiredInformation type', () => {
+	it( 'includes botNameSlug as a required field', () => {
+		const context: HelpCenterRequiredInformation = {
+			botNameSlug: 'wpcom-support-chat',
+			locale: 'en',
+			sectionName: 'test',
+			currentUser: {
+				ID: 1,
+				display_name: 'Test',
+				username: 'test',
+				email: 'test@test.com',
+				language: 'en',
+				localeSlug: 'en',
+				locale_variant: '',
+				localeVariant: '',
+				site_count: 1,
+			},
+			site: null,
+			hasPurchases: false,
+			primarySiteId: 0,
+			googleMailServiceFamily: '',
+			onboardingUrl: '',
+			isCommerceGarden: false,
+		};
+		expect( context.botNameSlug ).toBe( 'wpcom-support-chat' );
+	} );
+
+	it( 'allows different bot slug values in the context', () => {
+		const context: Partial< HelpCenterRequiredInformation > = {
+			botNameSlug: 'ciab-workflow-support_chat',
+			isCommerceGarden: true,
+		};
+		expect( context.botNameSlug ).toBe( 'ciab-workflow-support_chat' );
+	} );
+} );
+
+describe( 'HelpCenterContext default includes botNameSlug', () => {
+	let contextSource: string;
+
+	beforeAll( () => {
+		contextSource = fs.readFileSync(
+			path.join( __dirname, '..', 'contexts', 'HelpCenterContext.tsx' ),
+			'utf-8'
+		);
+	} );
+
+	it( 'default context object includes a botNameSlug value', () => {
+		const defaultContextMatch = contextSource.match(
+			/const\s+defaultContext[\s\S]*?=\s*\{([\s\S]*?)\};/
+		);
+		expect( defaultContextMatch ).toBeTruthy();
+		if ( defaultContextMatch ) {
+			expect( defaultContextMatch[ 1 ] ).toContain( 'botNameSlug' );
+		}
+	} );
+} );
