+import type { OdieAssistantProviderProps, SupportInteraction } from '../types';
+
+describe( 'SupportInteraction type', () => {
+	it( 'includes a bot_slug field', () => {
+		const interaction: SupportInteraction = {
+			bot_slug: 'wpcom-support-chat',
+			uuid: 'test-uuid',
+			status: 'open',
+			start_date: '2025-01-01',
+			last_updated: '2025-01-01',
+			users: [],
+			events: [],
+			environment: 'production',
+		};
+		expect( interaction.bot_slug ).toBe( 'wpcom-support-chat' );
+	} );
+
+	it( 'accepts different bot_slug values', () => {
+		const interaction: SupportInteraction = {
+			bot_slug: 'ciab-workflow-support_chat',
+			uuid: 'test-uuid-2',
+			status: 'open',
+			start_date: '2025-01-01',
+			last_updated: '2025-01-01',
+			users: [],
+			events: [],
+			environment: 'staging',
+		};
+		expect( interaction.bot_slug ).toBe( 'ciab-workflow-support_chat' );
+	} );
+} );
+
+describe( 'OdieAssistantProviderProps type', () => {
+	it( 'requires defaultBotNameSlug as a mandatory prop', () => {
+		const props: OdieAssistantProviderProps = {
+			defaultBotNameSlug: 'wpcom-support-chat',
+			currentUser: { display_name: 'Test User' },
+		};
+		expect( props.defaultBotNameSlug ).toBe( 'wpcom-support-chat' );
+	} );
+
+	it( 'does not have an optional botNameSlug prop', () => {
+		const props: OdieAssistantProviderProps = {
+			defaultBotNameSlug: 'wpcom-support-chat',
+			currentUser: { display_name: 'Test User' },
+		};
+		expect( 'botNameSlug' in props ).toBe( false );
+		expect( props ).not.toHaveProperty( 'botNameSlug' );
+	} );
+} );
