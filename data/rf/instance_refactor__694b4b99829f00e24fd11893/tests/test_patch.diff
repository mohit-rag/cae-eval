+def test_alias_create_uses_paid_rate_limits_for_premium_user():
+    user = create_new_user()
+    alias_email = f"test_{random_email()}"
+
+    with patch.object(User, 'is_premium', return_value=True):
+        with patch('app.rate_limiter.check_bucket_limit') as mock_check:
+            Alias.create(
+                user_id=user.id,
+                email=alias_email,
+                mailbox_id=user.default_mailbox_id,
+            )
+
+            assert mock_check.call_count == len(config.ALIAS_CREATE_RATE_LIMIT_PAID)
+            for i, limit in enumerate(config.ALIAS_CREATE_RATE_LIMIT_PAID):
+                call_args = mock_check.call_args_list[i]
+                key = call_args[0][0]
+                assert str(user.id) in key, f"Key should contain user ID {user.id}"
+                assert call_args[0][1] == limit[0]
+                assert call_args[0][2] == limit[1]
+
+
+def test_alias_create_uses_free_rate_limits_for_non_premium_user():
+    user = create_new_user()
+    alias_email = f"test_{random_email()}"
+
+    with patch.object(User, 'is_premium', return_value=False):
+        with patch('app.rate_limiter.check_bucket_limit') as mock_check:
+            Alias.create(
+                user_id=user.id,
+                email=alias_email,
+                mailbox_id=user.default_mailbox_id,
+            )
+
+            assert mock_check.call_count == len(config.ALIAS_CREATE_RATE_LIMIT_FREE)
+            for i, limit in enumerate(config.ALIAS_CREATE_RATE_LIMIT_FREE):
+                call_args = mock_check.call_args_list[i]
+                key = call_args[0][0]
+                assert str(user.id) in key, f"Key should contain user ID {user.id}"
+                assert call_args[0][1] == limit[0]
+                assert call_args[0][2] == limit[1]
+
+
+def test_alias_create_passes_seconds_directly_to_rate_limiter():
+    user = create_new_user()
+    alias_email = f"test_{random_email()}"
+
+    with patch.object(User, 'is_premium', return_value=False):
+        with patch('app.rate_limiter.check_bucket_limit') as mock_check:
+            Alias.create(
+                user_id=user.id,
+                email=alias_email,
+                mailbox_id=user.default_mailbox_id,
+            )
+
+            for i, limit in enumerate(config.ALIAS_CREATE_RATE_LIMIT_FREE):
+                call_args = mock_check.call_args_list[i]
+                bucket_seconds = call_args[0][2]
+                assert bucket_seconds == limit[1], (
+                    f"Expected bucket_seconds to be {limit[1]} (seconds), "
+                    f"not {limit[1] * 86400} (days converted to seconds). "
+                    f"Got {bucket_seconds}"
+                )
