@@ -1,6 +1,6 @@
 import pytest
 
-from app.config import sl_getenv
+from app.config import sl_getenv, getRateLimitFromConfig
 
 
 def test_sl_getenv(monkeypatch):
@@ -11,3 +11,45 @@ def test_sl_getenv(monkeypatch):
 
     with pytest.raises(TypeError):
         sl_getenv("SL_KEY_3")
+
+
+def test_getRateLimitFromConfig_parses_multiple_entries(monkeypatch):
+    monkeypatch.setenv("TEST_RATE_LIMIT", "10,900:50,3600")
+    result = getRateLimitFromConfig("TEST_RATE_LIMIT")
+    assert result == [(10, 900), (50, 3600)]
+
+
+def test_getRateLimitFromConfig_parses_single_entry(monkeypatch):
+    monkeypatch.setenv("TEST_RATE_LIMIT", "5,300")
+    result = getRateLimitFromConfig("TEST_RATE_LIMIT")
+    assert result == [(5, 300)]
+
+
+def test_getRateLimitFromConfig_returns_empty_list_when_env_not_set(monkeypatch):
+    monkeypatch.delenv("TEST_RATE_LIMIT_MISSING", raising=False)
+    result = getRateLimitFromConfig("TEST_RATE_LIMIT_MISSING")
+    assert result == []
+
+
+def test_getRateLimitFromConfig_returns_empty_list_for_empty_string(monkeypatch):
+    monkeypatch.setenv("TEST_RATE_LIMIT", "")
+    result = getRateLimitFromConfig("TEST_RATE_LIMIT")
+    assert result == []
+
+
+def test_getRateLimitFromConfig_uses_default_when_env_not_set(monkeypatch):
+    monkeypatch.delenv("TEST_RATE_LIMIT_DEFAULT", raising=False)
+    result = getRateLimitFromConfig("TEST_RATE_LIMIT_DEFAULT", "1,10:2,20")
+    assert result == [(1, 10), (2, 20)]
+
+
+def test_getRateLimitFromConfig_parses_large_values(monkeypatch):
+    monkeypatch.setenv("TEST_RATE_LIMIT", "1000,86400:5000,604800")
+    result = getRateLimitFromConfig("TEST_RATE_LIMIT")
+    assert result == [(1000, 86400), (5000, 604800)]
+
+
+def test_getRateLimitFromConfig_invalid_format_raises_error(monkeypatch):
+    monkeypatch.setenv("TEST_RATE_LIMIT", "invalid")
+    with pytest.raises(Exception):
+        getRateLimitFromConfig("TEST_RATE_LIMIT")
