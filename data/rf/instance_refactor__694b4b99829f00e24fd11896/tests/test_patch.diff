+class TestDeprecationWarnings(unittest.TestCase):
+    """Deprecated functions should use warnings.warn() with DeprecationWarning."""
+
+    def test_dnsgetstr_deprecation(self):
+        from scapy.layers.dns import DNSgetstr
+        with warnings.catch_warnings(record=True) as w:
+            warnings.simplefilter("always")
+            try:
+                DNSgetstr(b'\x00', 0)
+            except Exception:
+                pass
+            dep = [x for x in w if issubclass(x.category, DeprecationWarning)]
+            self.assertTrue(len(dep) > 0, "DNSgetstr should emit DeprecationWarning")
+
+    def test_flagrepr_deprecation(self):
+        from scapy.fields import FlagValue
+        with warnings.catch_warnings(record=True) as w:
+            warnings.simplefilter("always")
+            fv = FlagValue(3, ['a', 'b', 'c'])
+            fv.flagrepr()
+            dep = [x for x in w if issubclass(x.category, DeprecationWarning)]
+            self.assertTrue(len(dep) > 0, "flagrepr() should emit DeprecationWarning")
+
+    def test_do_graph_type_deprecation(self):
+        from scapy.utils import do_graph
+        with warnings.catch_warnings(record=True) as w:
+            warnings.simplefilter("always")
+            try:
+                do_graph("digraph { a -> b }", type="png")
+            except Exception:
+                pass
+            dep = [x for x in w if issubclass(x.category, DeprecationWarning)]
+            self.assertTrue(len(dep) > 0,
+                            "do_graph(type=...) should emit DeprecationWarning")
+
+    def test_conf_iface6_deprecation(self):
+        with warnings.catch_warnings(record=True) as w:
+            warnings.simplefilter("always")
+            from scapy.config import conf
+            try:
+                _ = conf.iface6
+            except Exception:
+                pass
+            dep = [x for x in w if issubclass(x.category, DeprecationWarning)]
+            self.assertTrue(len(dep) > 0,
+                            "conf.iface6 should emit DeprecationWarning")
+
+    def test_answering_machine_run_deprecation(self):
+        from scapy.ansmachine import AnsweringMachine
+        with warnings.catch_warnings(record=True) as w:
+            warnings.simplefilter("always")
+            class _NoOpCallable:
+                def __call__(self, *a, **k):
+                    pass
+            stub = _NoOpCallable()
+            AnsweringMachine.run(stub)
+            dep = [x for x in w if issubclass(x.category, DeprecationWarning)]
+            self.assertTrue(len(dep) > 0,
+                            "AnsweringMachine.run() should emit DeprecationWarning")
+
+
+class TestScapyFreqFilter(unittest.TestCase):
+    """ScapyFreqFilter should return proper booleans and not throttle low-level messages."""
+
+    def test_filter_returns_boolean(self):
+        from scapy.error import ScapyFreqFilter
+        f = ScapyFreqFilter()
+        record = logging.LogRecord('test', logging.WARNING, '', 0, 'msg', (), None)
+        result = f.filter(record)
+        self.assertIsInstance(result, bool)
+
+    def test_info_level_passes_through(self):
+        from scapy.error import ScapyFreqFilter
+        f = ScapyFreqFilter()
+        record = logging.LogRecord('test', logging.INFO, '', 0, 'msg', (), None)
+        result = f.filter(record)
+        self.assertTrue(result)
+        self.assertIsInstance(result, bool)
+
+    def test_debug_level_passes_through(self):
+        from scapy.error import ScapyFreqFilter
+        f = ScapyFreqFilter()
+        record = logging.LogRecord('test', logging.DEBUG, '', 0, 'msg', (), None)
+        result = f.filter(record)
+        self.assertTrue(result)
+
+
