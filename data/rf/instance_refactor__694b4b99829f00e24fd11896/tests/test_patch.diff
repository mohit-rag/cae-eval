+class TestIPv6DissectionLogLevel(unittest.TestCase):
+    """IPv6 dissection messages should be at INFO level."""
+
+    def test_ipv6_jumbo_not_found_is_info(self):
+        from scapy.layers.inet6 import IPv6, IPv6ExtHdrHopByHop, Pad1
+        from scapy.compat import raw
+        with LogCapture("scapy.runtime") as cap:
+            pkt = IPv6(nh=0) / IPv6ExtHdrHopByHop(options=[Pad1()])
+            raw_bytes = raw(pkt)
+            raw_bytes = raw_bytes[:4] + b'\x00\x00' + raw_bytes[6:]
+            IPv6(raw_bytes)
+            jumbo_msgs = cap.messages_containing("Jumbo")
+            self.assertTrue(len(jumbo_msgs) > 0, "Should log Jumbo option message")
+            for r in jumbo_msgs:
+                self.assertLessEqual(r.levelno, logging.INFO)
+
