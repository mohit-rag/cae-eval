+"""
+Tests for logging regularization changes.
+Verifies that Scapy's logging is properly structured:
+- Packet dissection messages are at INFO level (not WARNING)
+- Deprecated functions emit DeprecationWarning via warnings.warn()
+- Console handler is set up on import (not deferred to interact())
+- ScapyFreqFilter returns proper booleans
+- Miscellaneous logging cleanups
+"""
+
+import logging
+import struct
+import unittest
+import warnings
+
+
+class LogCapture:
+    """Captures log records from a given logger for assertion."""
+    def __init__(self, logger_name, level=logging.DEBUG):
+        self.records = []
+        self.logger = logging.getLogger(logger_name)
+        self.handler = logging.Handler()
+        self.handler.emit = lambda record: self.records.append(record)
+        self.old_level = self.logger.level
+        self.level = level
+
+    def __enter__(self):
+        self.logger.addHandler(self.handler)
+        self.logger.setLevel(self.level)
+        return self
+
+    def __exit__(self, *args):
+        self.logger.removeHandler(self.handler)
+        self.logger.setLevel(self.old_level)
+
+    def messages_at_level(self, level):
+        return [r for r in self.records if r.levelno == level]
+
+    def messages_containing(self, text):
+        return [r for r in self.records if text in r.getMessage()]
+
+
+class TestLoggerHandlerInitialization(unittest.TestCase):
+    """The console handler should be configured on import, not in interact()."""
+
+    def test_scapy_logger_has_stream_handler(self):
+        from scapy.error import log_scapy
+        handler_types = [type(h).__name__ for h in log_scapy.handlers]
+        self.assertIn("StreamHandler", handler_types)
+
+    def test_scapy_logger_no_null_handler_only(self):
+        from scapy.error import log_scapy
+        handler_types = [type(h).__name__ for h in log_scapy.handlers]
+        self.assertFalse(
+            handler_types == ["NullHandler"],
+            "Logger should not have only a NullHandler"
+        )
+
+    def test_handler_uses_colored_formatter(self):
+        from scapy.error import log_scapy, ScapyColoredFormatter
+        stream_handlers = [
+            h for h in log_scapy.handlers
+            if isinstance(h, logging.StreamHandler) and not isinstance(h, logging.FileHandler)
+        ]
+        self.assertTrue(len(stream_handlers) > 0, "Should have at least one StreamHandler")
+        has_colored = any(
+            isinstance(h.formatter, ScapyColoredFormatter) for h in stream_handlers
+        )
+        self.assertTrue(has_colored, "StreamHandler should use ScapyColoredFormatter")
+
+    def test_logger_default_level_is_warning(self):
+        from scapy.error import log_scapy
+        self.assertEqual(log_scapy.level, logging.WARNING)
+
+
+class TestDNSDissectionLogLevel(unittest.TestCase):
+    """DNS dissection messages should be at INFO level, not WARNING."""
+
+    def test_dns_premature_end_is_info(self):
+        from scapy.layers.dns import dns_get_str
+        with LogCapture("scapy.runtime") as cap:
+            dns_get_str(b'\x05abc', 0)
+            premature = cap.messages_containing("prematured end")
+            self.assertTrue(len(premature) > 0, "Should log premature end message")
+            for r in premature:
+                self.assertLessEqual(r.levelno, logging.INFO)
+
+    def test_bitmap_too_short_is_info(self):
+        from scapy.layers.dns import bitmap2RRlist
+        with LogCapture("scapy.runtime") as cap:
+            bitmap2RRlist(b'\x00')
+            short = cap.messages_containing("bitmap too short")
+            self.assertTrue(len(short) > 0, "Should log bitmap too short")
+            for r in short:
+                self.assertLessEqual(r.levelno, logging.INFO)
+
+    def test_bitmap_length_invalid_is_info(self):
+        from scapy.layers.dns import bitmap2RRlist
+        with LogCapture("scapy.runtime") as cap:
+            bitmap2RRlist(b'\x00\xff' + b'\x00' * 255)
+            invalid = cap.messages_containing("bitmap length")
+            self.assertTrue(len(invalid) > 0, "Should log bitmap length invalid")
+            for r in invalid:
+                self.assertLessEqual(r.levelno, logging.INFO)
+
+    def test_dns_wrong_value_is_info(self):
+        from scapy.layers.dns import DNS
+        with LogCapture("scapy.runtime") as cap:
+            raw = struct.pack('!HHHHHH', 0x1234, 0x0100, 0, 50, 0, 0)
+            raw += b'\x00' * 4
+            try:
+                DNS(raw)
+            except Exception:
+                pass
+            wrong_val = cap.messages_containing("wrong value")
+            self.assertTrue(len(wrong_val) > 0, "Should log wrong value message")
+            for r in wrong_val:
+                self.assertLessEqual(r.levelno, logging.INFO)
+
+    def test_dns_dissection_not_at_warning(self):
+        from scapy.layers.dns import dns_get_str, bitmap2RRlist
+        with LogCapture("scapy.runtime") as cap:
+            dns_get_str(b'\x05abc', 0)
+            bitmap2RRlist(b'\x00')
+            warnings_logged = cap.messages_at_level(logging.WARNING)
+            dns_warnings = [
+                r for r in warnings_logged
+                if any(kw in r.getMessage() for kw in ["prematured", "bitmap", "DNS"])
+            ]
+            self.assertEqual(len(dns_warnings), 0,
+                             "DNS dissection should not produce WARNING-level messages")
+
+
+class TestTCPIPDissectionLogLevel(unittest.TestCase):
+    """TCP/IP dissection messages should be at INFO level."""
+
+    def test_no_underlayer_checksum_is_info(self):
+        from scapy.layers.inet import TCP
+        with LogCapture("scapy.runtime") as cap:
+            pkt = TCP()
+            bytes(pkt)
+            checksum_msgs = cap.messages_containing("underlayer")
+            self.assertTrue(len(checksum_msgs) > 0, "Should log underlayer checksum message")
+            for r in checksum_msgs:
+                self.assertLessEqual(r.levelno, logging.INFO)
+
+    def test_tcp_bad_dataofs_is_info(self):
+        from scapy.layers.inet import TCP
+        with LogCapture("scapy.runtime") as cap:
+            raw_tcp = struct.pack('!HHIIBBHHH',
+                                  80, 80, 0, 0, (3 << 4), 0x02, 8192, 0, 0)
+            raw_tcp += b'\x00' * 4
+            TCP(raw_tcp)
+            bad_msgs = cap.messages_containing("bad dataofs")
+            self.assertTrue(len(bad_msgs) > 0, "Should log bad dataofs message")
+            for r in bad_msgs:
+                self.assertLessEqual(r.levelno, logging.INFO)
+
+    def test_udp_no_underlayer_is_info(self):
+        from scapy.layers.inet import UDP
+        with LogCapture("scapy.runtime") as cap:
+            pkt = UDP()
+            bytes(pkt)
+            underlayer_msgs = cap.messages_containing("underlayer")
+            self.assertTrue(len(underlayer_msgs) > 0, "Should log underlayer message")
+            for r in underlayer_msgs:
+                self.assertLessEqual(r.levelno, logging.INFO)
+
+    def test_tcp_malformed_option_is_info(self):
+        from scapy.layers.inet import TCP
+        with LogCapture("scapy.runtime") as cap:
+            raw_tcp = struct.pack('!HHIIBBHHH',
+                                  80, 80, 0, 0, (6 << 4), 0x02, 8192, 0, 0)
+            raw_tcp += bytes([0x02, 0x01, 0x00, 0x00])
+            TCP(raw_tcp)
+            malformed_msgs = cap.messages_containing("Malformed TCP option")
+            self.assertTrue(len(malformed_msgs) > 0, "Should log malformed TCP option")
+            for r in malformed_msgs:
+                self.assertLessEqual(r.levelno, logging.INFO)
+
