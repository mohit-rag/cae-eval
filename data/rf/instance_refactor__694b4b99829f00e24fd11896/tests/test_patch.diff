+class TestAutomatonDebugLogLevel(unittest.TestCase):
+    """Automaton should set log level to DEBUG when debug mode is enabled."""
+
+    def test_automaton_respects_debug_mode(self):
+        from scapy.automaton import Automaton
+        from scapy.error import log_scapy, log_runtime
+        old_scapy_level = log_scapy.level
+        old_runtime_level = log_runtime.level
+        try:
+            class _Stub:
+                pass
+            stub = _Stub()
+            Automaton.parse_args(stub, debug=1)
+            self.assertLessEqual(log_runtime.getEffectiveLevel(), logging.DEBUG,
+                                 "Automaton debug mode should enable debug-level logging")
+        finally:
+            log_scapy.setLevel(old_scapy_level)
+            log_runtime.setLevel(old_runtime_level)
+
+
+class TestDNSDissectionLogLevelExtended(unittest.TestCase):
+    """Additional DNS dissection messages should be at INFO level."""
+
+    def test_dns_incomplete_jump_is_info(self):
+        from scapy.layers.dns import dns_get_str
+        with LogCapture("scapy.runtime") as cap:
+            raw = b'\xc0'
+            dns_get_str(raw, 0)
+            jump_msgs = cap.messages_containing("incomplete jump")
+            self.assertTrue(len(jump_msgs) > 0, "Should log incomplete jump message")
+            for r in jump_msgs:
+                self.assertLessEqual(r.levelno, logging.INFO)
+
+    def test_dns_malformed_message_is_info(self):
+        from scapy.layers.inet import IP, TCP
+        from scapy.packet import Raw
+        import scapy.layers.dns
+        with LogCapture("scapy.runtime") as cap:
+            try:
+                raw_pkt = bytes(IP() / TCP(dport=53) / Raw(b'\x00'))
+                IP(raw_pkt)
+            except Exception:
+                pass
+            malformed = cap.messages_containing("Malformed")
+            self.assertTrue(len(malformed) > 0, "Should log malformed message")
+            for r in malformed:
+                self.assertLessEqual(r.levelno, logging.INFO)
+
+    def test_dns_txt_premature_end_is_info(self):
+        from scapy.layers.dns import DNSTextField
+        with LogCapture("scapy.runtime") as cap:
+            field = DNSTextField("data", "")
+            try:
+                field.m2i(None, b'\xff' + b'a' * 10)
+            except Exception:
+                pass
+            txt_msgs = cap.messages_containing("TXT")
+            self.assertTrue(len(txt_msgs) > 0, "Should log TXT premature end message")
+            for r in txt_msgs:
+                self.assertLessEqual(r.levelno, logging.INFO)
+
+
+if __name__ == '__main__':
+    unittest.main()
