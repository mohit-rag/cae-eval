+class TestPipetoolLoggerUsage(unittest.TestCase):
+    """Pipe engine lifecycle messages should use runtime logger at debug level."""
+
+    def test_pipe_engine_already_running_is_debug(self):
+        from scapy.pipetool import PipeEngine
+        pe = PipeEngine()
+        pe.thread_lock.acquire()
+        try:
+            with LogCapture("scapy.runtime") as cap:
+                pe.start()
+                already = cap.messages_containing("already running")
+                self.assertTrue(len(already) > 0,
+                                "Should log 'already running' message")
+                for r in already:
+                    self.assertEqual(r.levelno, logging.DEBUG)
+        finally:
+            pe.thread_lock.release()
+
+    def test_pipe_engine_not_running_is_debug(self):
+        from scapy.pipetool import PipeEngine
+        pe = PipeEngine()
+        with LogCapture("scapy.runtime") as cap:
+            pe.stop()
+            not_running = cap.messages_containing("not running")
+            self.assertTrue(len(not_running) > 0,
+                            "Should log 'not running' message")
+            for r in not_running:
+                self.assertEqual(r.levelno, logging.DEBUG)
+
+
+class TestContributingDocumentation(unittest.TestCase):
+    """Project documentation should have logging guidelines."""
+
+    DOC_FILES = [
+        "CONTRIBUTING.md",
+        "doc/scapy/development.rst",
+        "doc/scapy/contributing.rst",
+    ]
+
+    def _read_any_doc(self):
+        combined = ""
+        for path in self.DOC_FILES:
+            try:
+                with open(path) as f:
+                    combined += f.read() + "\n"
+            except FileNotFoundError:
+                continue
+        return combined
+
+    def test_docs_have_logging_guidelines(self):
+        content = self._read_any_doc()
+        content_lower = content.lower()
+        has_section = ("logging" in content_lower and
+                       ("log_runtime" in content or
+                        "log_loading" in content or
+                        "log_interactive" in content))
+        self.assertTrue(has_section,
+                        "Project docs should have logging guidelines mentioning scapy loggers")
+
+    def test_docs_mention_log_levels(self):
+        content = self._read_any_doc()
+        has_logger = ("log_runtime" in content or "log_loading" in content)
+        has_level = ("INFO" in content or "info" in content or
+                     "WARNING" in content or "warning" in content)
+        self.assertTrue(has_logger and has_level,
+                        "Project docs logging section should discuss loggers and levels")
+
+
