+// ---------------------------------------------------------------------------
+// daemon-status-file.c: version-gated parsing for backward compat
+// ---------------------------------------------------------------------------
+
+func TestJsonParserHasVersionGatedLogic(t *testing.T) {
+	content := readFile(t, "src/daemon/daemon-status-file.c")
+
+	// Find the parser function body
+	fnIdx := strings.Index(content, "daemon_status_file_from_json")
+	if fnIdx == -1 {
+		t.Fatal("could not find daemon_status_file_from_json function")
+	}
+	braceIdx := strings.Index(content[fnIdx:], "{")
+	if braceIdx == -1 {
+		t.Fatal("could not find opening brace of daemon_status_file_from_json")
+	}
+	bodyStart := fnIdx + braceIdx
+	bodyEnd := minInt(bodyStart+8000, len(content))
+	body := content[bodyStart:bodyEnd]
+
+	// The parser must reference the version variable in conditional logic
+	// to differentiate field requirements between old and new format versions.
+	// This can be done via version-gated booleans (e.g. version >= N), switch/case,
+	// if-else on version, or any other mechanism that uses the parsed version.
+	versionGatePatterns := []string{
+		"version >=",
+		"version >",
+		"version ==",
+		"version !=",
+		"version <=",
+		"version <",
+		"switch(version",
+		"switch (version",
+	}
+	gateCount := 0
+	for _, pat := range versionGatePatterns {
+		gateCount += strings.Count(body, pat)
+	}
+	if gateCount < 2 {
+		t.Errorf("JSON parser should contain version-gated logic (e.g. version >= N checks) to handle old and new formats; found %d version comparisons", gateCount)
+	}
+}
