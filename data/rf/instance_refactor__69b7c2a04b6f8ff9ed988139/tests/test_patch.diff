+func TestHashFunctionUsesMultipleFields(t *testing.T) {
+	content := readFile(t, "src/daemon/daemon-status-file.c")
+	funcNames := []string{
+		"daemon_status_file_hash", "daemon_status_file_compute_content_hash",
+		"crash_hash", "compute_hash", "compute_content_hash",
+		"dedup_hash", "status_file_hash",
+	}
+	var funcBody string
+	for _, name := range funcNames {
+		searchFrom := 0
+		for searchFrom < len(content) {
+			idx := strings.Index(content[searchFrom:], name)
+			if idx == -1 {
+				break
+			}
+			absIdx := searchFrom + idx
+			braceIdx := strings.Index(content[absIdx:], "{")
+			if braceIdx == -1 {
+				break
+			}
+			candidate := content[absIdx : absIdx+braceIdx]
+			if strings.Contains(candidate, ";") {
+				searchFrom = absIdx + len(name)
+				continue
+			}
+			start := absIdx + braceIdx
+			funcBody = content[start:minInt(start+3000, len(content))]
+			break
+		}
+		if funcBody != "" {
+			break
+		}
+	}
+	if funcBody == "" {
+		t.Skip("hash function not found by name; skipping field check")
+	}
+	fieldChecks := 0
+	for _, field := range []string{"fatal", "filename", "function", "message", "stack_trace", "status", "errno", "line"} {
+		if strings.Contains(funcBody, field) {
+			fieldChecks++
+		}
+	}
+	if fieldChecks < 3 {
+		t.Errorf("hash function should incorporate multiple crash context fields; only found %d of the expected fields", fieldChecks)
+	}
+}
