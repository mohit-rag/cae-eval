@@ -0,0 +1,191 @@
+package unifiedSearch
+
+import (
+	"encoding/json"
+	"testing"
+	"time"
+
+	"github.com/stretchr/testify/assert"
+	"github.com/stretchr/testify/require"
+)
+
+func TestGetDoc_ValidJSON(t *testing.T) {
+	input := `{
+		"Uid": "abc-123",
+		"Group": "dashboard.grafana.app",
+		"Namespace": "default",
+		"Kind": "Dashboard",
+		"Name": "my-dashboard",
+		"CreatedAt": "2024-01-01T00:00:00Z",
+		"CreatedBy": "admin",
+		"UpdatedAt": "2024-06-01T12:00:00Z",
+		"UpdatedBy": "editor",
+		"FolderId": "folder-1",
+		"Spec": {"title": "My Dashboard"}
+	}`
+
+	doc, err := getDoc([]byte(input))
+	require.NoError(t, err)
+	require.NotNil(t, doc)
+
+	assert.Equal(t, "abc-123", doc.UID)
+	assert.Equal(t, "dashboard.grafana.app", doc.Group)
+	assert.Equal(t, "default", doc.Namespace)
+	assert.Equal(t, "Dashboard", doc.Kind)
+	assert.Equal(t, "my-dashboard", doc.Name)
+	assert.Equal(t, "admin", doc.CreatedBy)
+	assert.Equal(t, "editor", doc.UpdatedBy)
+	assert.Equal(t, "folder-1", doc.FolderID)
+	assert.Equal(t, "My Dashboard", doc.Spec.Title)
+
+	expectedCreated := time.Date(2024, 1, 1, 0, 0, 0, 0, time.UTC)
+	assert.True(t, doc.CreatedAt.Equal(expectedCreated))
+
+	expectedUpdated := time.Date(2024, 6, 1, 12, 0, 0, 0, time.UTC)
+	assert.True(t, doc.UpdatedAt.Equal(expectedUpdated))
+}
+
+func TestGetDoc_InvalidJSON(t *testing.T) {
+	doc, err := getDoc([]byte("not valid json"))
+	assert.Error(t, err)
+	assert.Nil(t, doc)
+}
+
+func TestGetDoc_EmptyInput(t *testing.T) {
+	doc, err := getDoc([]byte(""))
+	assert.Error(t, err)
+	assert.Nil(t, doc)
+}
+
+func TestGetDoc_EmptyObject(t *testing.T) {
+	doc, err := getDoc([]byte("{}"))
+	require.NoError(t, err)
+	require.NotNil(t, doc)
+
+	assert.Equal(t, "", doc.UID)
+	assert.Equal(t, "", doc.Kind)
+	assert.Equal(t, "", doc.Name)
+	assert.Equal(t, "", doc.FolderID)
+	assert.Equal(t, "", doc.Spec.Title)
+}
+
+func TestGetDoc_PartialFields(t *testing.T) {
+	input := `{"Uid": "partial-uid", "Kind": "Folder"}`
+
+	doc, err := getDoc([]byte(input))
+	require.NoError(t, err)
+	require.NotNil(t, doc)
+
+	assert.Equal(t, "partial-uid", doc.UID)
+	assert.Equal(t, "Folder", doc.Kind)
+	assert.Equal(t, "", doc.Group)
+	assert.Equal(t, "", doc.FolderID)
+	assert.Equal(t, "", doc.Spec.Title)
+}
+
+func TestGetDoc_SpecWithEmptyTitle(t *testing.T) {
+	input := `{"Uid": "uid-1", "Kind": "Dashboard", "Spec": {"title": ""}}`
+
+	doc, err := getDoc([]byte(input))
+	require.NoError(t, err)
+	assert.Equal(t, "", doc.Spec.Title)
+}
+
+func TestGetDoc_SpecWithSpecialCharacters(t *testing.T) {
+	input := `{"Uid": "uid-2", "Kind": "Dashboard", "Spec": {"title": "Dashboard with \"quotes\" & <special> chars"}}`
+
+	doc, err := getDoc([]byte(input))
+	require.NoError(t, err)
+	assert.Equal(t, "Dashboard with \"quotes\" & <special> chars", doc.Spec.Title)
+}
+
+func TestGetDoc_NullInput(t *testing.T) {
+	doc, err := getDoc(nil)
+	assert.Error(t, err)
+	assert.Nil(t, doc)
+}
+
+func TestCustomMeta_JSONSerialization(t *testing.T) {
+	meta := customMeta{
+		Count:    42,
+		MaxScore: 1.5,
+		SortBy:   "name_sort",
+	}
+
+	data, err := json.Marshal(meta)
+	require.NoError(t, err)
+
+	var decoded map[string]interface{}
+	err = json.Unmarshal(data, &decoded)
+	require.NoError(t, err)
+
+	assert.Equal(t, float64(42), decoded["count"])
+	assert.Equal(t, 1.5, decoded["max_score"])
+	assert.Equal(t, "name_sort", decoded["sortBy"])
+}
+
+func TestCustomMeta_OmitsEmptyFields(t *testing.T) {
+	meta := customMeta{
+		Count: 10,
+	}
+
+	data, err := json.Marshal(meta)
+	require.NoError(t, err)
+
+	var decoded map[string]interface{}
+	err = json.Unmarshal(data, &decoded)
+	require.NoError(t, err)
+
+	assert.Equal(t, float64(10), decoded["count"])
+	_, hasMaxScore := decoded["max_score"]
+	assert.False(t, hasMaxScore, "max_score should be omitted when zero")
+	_, hasSortBy := decoded["sortBy"]
+	assert.False(t, hasSortBy, "sortBy should be omitted when empty")
+}
+
+func TestCustomMeta_ZeroCount(t *testing.T) {
+	meta := customMeta{
+		Count: 0,
+	}
+
+	data, err := json.Marshal(meta)
+	require.NoError(t, err)
+
+	var decoded map[string]interface{}
+	err = json.Unmarshal(data, &decoded)
+	require.NoError(t, err)
+
+	assert.Equal(t, float64(0), decoded["count"])
+}
+
+func TestDashboardListDoc_JSONDeserialization(t *testing.T) {
+	input := `{
+		"Uid": "dash-1",
+		"Group": "dashboard.grafana.app",
+		"Namespace": "org-1",
+		"Kind": "Dashboard",
+		"Name": "test-dash",
+		"CreatedAt": "2024-03-15T10:30:00Z",
+		"CreatedBy": "user1",
+		"UpdatedAt": "2024-03-16T14:00:00Z",
+		"UpdatedBy": "user2",
+		"FolderId": "folder-abc",
+		"Spec": {"title": "Test Dashboard"}
+	}`
+
+	var doc DashboardListDoc
+	err := json.Unmarshal([]byte(input), &doc)
+	require.NoError(t, err)
+
+	assert.Equal(t, "dash-1", doc.UID)
+	assert.Equal(t, "dashboard.grafana.app", doc.Group)
+	assert.Equal(t, "org-1", doc.Namespace)
+	assert.Equal(t, "Dashboard", doc.Kind)
+	assert.Equal(t, "test-dash", doc.Name)
+	assert.Equal(t, "user1", doc.CreatedBy)
+	assert.Equal(t, "user2", doc.UpdatedBy)
+	assert.Equal(t, "folder-abc", doc.FolderID)
+	assert.Equal(t, "Test Dashboard", doc.Spec.Title)
+	assert.Equal(t, time.Date(2024, 3, 15, 10, 30, 0, 0, time.UTC), doc.CreatedAt)
+	assert.Equal(t, time.Date(2024, 3, 16, 14, 0, 0, 0, time.UTC), doc.UpdatedAt)
+}
