+
+  it('should return SQLSearcher when no feature toggles are enabled', () => {
+    jest.isolateModules(() => {
+      const { config: cfg } = require('@grafana/runtime');
+      cfg.featureToggles = {};
+
+      const { getGrafanaSearcher: getSearcher } = require('./searcher');
+      const searcher = getSearcher();
+      expect(searcher).toHaveProperty('type', 'sql');
+    });
+  });
+
+  it('should return FrontendSearcher when panelTitleSearch and do-frontend-query are active', () => {
