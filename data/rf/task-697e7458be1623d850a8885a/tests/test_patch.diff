@@ -0,0 +1,436 @@
+import { DataFrameJSON, getDisplayProcessor, toDataFrame } from '@grafana/data';
+import { config, getBackendSrv } from '@grafana/runtime';
+
+import { GrafanaSearcher, QueryResponse, SearchQuery } from '.';
+
+import { UnifiedSearcher } from './unified';
+
+jest.mock('@grafana/data', () => {
+  const actual = jest.requireActual('@grafana/data');
+  return {
+    ...actual,
+    getDisplayProcessor: jest.fn().mockReturnValue((value: any) => ({ text: String(value ?? ''), numeric: 0 })),
+  };
+});
+
+jest.mock('@grafana/runtime', () => {
+  const actual = jest.requireActual('@grafana/runtime');
+  return {
+    ...actual,
+    getBackendSrv: jest.fn(),
+    config: {
+      ...actual.config,
+      theme2: {},
+      featureToggles: {},
+      licenseInfo: {
+        enabledFeatures: {
+          analytics: false,
+        },
+      },
+    },
+  };
+});
+
+jest.mock('./utils', () => ({
+  replaceCurrentFolderQuery: jest.fn((q: SearchQuery) => Promise.resolve(q)),
+}));
+
+const mockBackendSrv = {
+  get: jest.fn(),
+  post: jest.fn(),
+};
+
+beforeEach(() => {
+  jest.clearAllMocks();
+  (getBackendSrv as jest.Mock).mockReturnValue(mockBackendSrv);
+});
+
+function createFallbackSearcher(): GrafanaSearcher {
+  return {
+    search: jest.fn().mockResolvedValue({ view: { dataFrame: { length: 0, fields: [] } }, totalRows: 0 }),
+    starred: jest.fn().mockResolvedValue({ view: { dataFrame: { length: 0, fields: [] } }, totalRows: 0 }),
+    tags: jest.fn().mockResolvedValue([]),
+    getSortOptions: jest.fn().mockResolvedValue([]),
+    getFolderViewSort: jest.fn().mockReturnValue('name_sort'),
+  } as unknown as GrafanaSearcher;
+}
+
+function makeSearchResponse(frames: DataFrameJSON[]): { frames: DataFrameJSON[] } {
+  return { frames };
+}
+
+function makeResultFrame(name: string, count: number): DataFrameJSON {
+  return {
+    schema: {
+      name,
+      fields: [
+        { name: 'kind', type: 'string' as any },
+        { name: 'uid', type: 'string' as any },
+        { name: 'name', type: 'string' as any },
+        { name: 'url', type: 'string' as any },
+        { name: 'tags', type: 'other' as any },
+        { name: 'location', type: 'string' as any },
+      ],
+      meta: {
+        custom: {
+          count,
+          max_score: 1,
+          locationInfo: {},
+        },
+      },
+    },
+    data: {
+      values: [
+        ['dashboard'],
+        ['uid-1'],
+        ['Test Dashboard'],
+        ['/d/uid-1'],
+        [null],
+        ['folder-1'],
+      ],
+    },
+  };
+}
+
+describe('UnifiedSearcher', () => {
+  describe('search', () => {
+    it('should return results from the unified search API', async () => {
+      const fallback = createFallbackSearcher();
+      const searcher = new UnifiedSearcher(fallback);
+
+      mockBackendSrv.post.mockResolvedValue(makeSearchResponse([makeResultFrame('Query results', 1)]));
+
+      const result = await searcher.search({ query: 'test' });
+      expect(result.totalRows).toBe(1);
+      expect(result.view.dataFrame.length).toBe(1);
+      expect(mockBackendSrv.post).toHaveBeenCalledWith(
+        'api/unified-search',
+        expect.objectContaining({ query: 'test' })
+      );
+    });
+
+    it('should throw error when facets are requested', async () => {
+      const fallback = createFallbackSearcher();
+      const searcher = new UnifiedSearcher(fallback);
+
+      await expect(
+        searcher.search({ query: 'test', facet: [{ field: 'type' }] })
+      ).rejects.toThrow('facets not supported!');
+    });
+
+    it('should use default query "*" when query is undefined', async () => {
+      const fallback = createFallbackSearcher();
+      const searcher = new UnifiedSearcher(fallback);
+
+      mockBackendSrv.post.mockResolvedValue(makeSearchResponse([makeResultFrame('Query results', 0)]));
+
+      await searcher.search({});
+      expect(mockBackendSrv.post).toHaveBeenCalledWith(
+        'api/unified-search',
+        expect.objectContaining({ query: '*' })
+      );
+    });
+
+    it('should fall back when backend returns Loading frame', async () => {
+      const fallback = createFallbackSearcher();
+      const searcher = new UnifiedSearcher(fallback);
+
+      const loadingFrame: DataFrameJSON = {
+        schema: {
+          name: 'Loading',
+          fields: [],
+        },
+        data: { values: [] },
+      };
+      mockBackendSrv.post.mockResolvedValue(makeSearchResponse([loadingFrame]));
+
+      await searcher.search({ query: 'test' });
+      expect(fallback.search).toHaveBeenCalled();
+    });
+
+    it('should default limit to 50 when not specified', async () => {
+      const fallback = createFallbackSearcher();
+      const searcher = new UnifiedSearcher(fallback);
+
+      mockBackendSrv.post.mockResolvedValue(makeSearchResponse([makeResultFrame('Query results', 0)]));
+
+      await searcher.search({ query: 'test' });
+      expect(mockBackendSrv.post).toHaveBeenCalledWith(
+        'api/unified-search',
+        expect.objectContaining({ limit: 50 })
+      );
+    });
+
+    it('should use provided limit when specified', async () => {
+      const fallback = createFallbackSearcher();
+      const searcher = new UnifiedSearcher(fallback);
+
+      mockBackendSrv.post.mockResolvedValue(makeSearchResponse([makeResultFrame('Query results', 0)]));
+
+      await searcher.search({ query: 'test', limit: 25 });
+      expect(mockBackendSrv.post).toHaveBeenCalledWith(
+        'api/unified-search',
+        expect.objectContaining({ limit: 25 })
+      );
+    });
+
+    it('should set default meta when custom meta is missing', async () => {
+      const fallback = createFallbackSearcher();
+      const searcher = new UnifiedSearcher(fallback);
+
+      const frameNoMeta: DataFrameJSON = {
+        schema: {
+          name: 'Query results',
+          fields: [
+            { name: 'kind', type: 'string' as any },
+          ],
+        },
+        data: { values: [[]] },
+      };
+      mockBackendSrv.post.mockResolvedValue(makeSearchResponse([frameNoMeta]));
+
+      const result = await searcher.search({ query: 'test' });
+      expect(result.totalRows).toBeDefined();
+    });
+
+    it('should handle empty response frames', async () => {
+      const fallback = createFallbackSearcher();
+      const searcher = new UnifiedSearcher(fallback);
+
+      mockBackendSrv.post.mockResolvedValue(makeSearchResponse([]));
+
+      const result = await searcher.search({ query: 'test' });
+      expect(result.totalRows).toBeDefined();
+    });
+  });
+
+  describe('starred', () => {
+    it('should throw error when facets are requested', async () => {
+      const fallback = createFallbackSearcher();
+      const searcher = new UnifiedSearcher(fallback);
+
+      await expect(
+        searcher.starred({ query: 'test', facet: [{ field: 'type' }] })
+      ).rejects.toThrow('facets not supported!');
+    });
+
+    it('should return empty response when no stars exist', async () => {
+      const fallback = createFallbackSearcher();
+      const searcher = new UnifiedSearcher(fallback);
+
+      mockBackendSrv.get.mockResolvedValue([]);
+
+      const result = await searcher.starred({ query: 'test' });
+      expect(result.totalRows).toBe(0);
+      expect(result.isItemLoaded(0)).toBe(true);
+    });
+
+    it('should return empty response when stars API returns null', async () => {
+      const fallback = createFallbackSearcher();
+      const searcher = new UnifiedSearcher(fallback);
+
+      mockBackendSrv.get.mockResolvedValue(null);
+
+      const result = await searcher.starred({ query: 'test' });
+      expect(result.totalRows).toBe(0);
+    });
+
+    it('should search with starred UIDs when stars exist', async () => {
+      const fallback = createFallbackSearcher();
+      const searcher = new UnifiedSearcher(fallback);
+
+      mockBackendSrv.get.mockResolvedValue(['uid-1', 'uid-2']);
+      mockBackendSrv.post.mockResolvedValue(makeSearchResponse([makeResultFrame('Query results', 2)]));
+
+      const result = await searcher.starred({ query: 'my query' });
+      expect(mockBackendSrv.post).toHaveBeenCalledWith(
+        'api/unified-search',
+        expect.objectContaining({
+          uid: ['uid-1', 'uid-2'],
+          query: 'my query',
+        })
+      );
+      expect(result.totalRows).toBe(2);
+    });
+
+    it('should use default query "*" when query.query is undefined', async () => {
+      const fallback = createFallbackSearcher();
+      const searcher = new UnifiedSearcher(fallback);
+
+      mockBackendSrv.get.mockResolvedValue(['uid-1']);
+      mockBackendSrv.post.mockResolvedValue(makeSearchResponse([makeResultFrame('Query results', 1)]));
+
+      await searcher.starred({});
+      expect(mockBackendSrv.post).toHaveBeenCalledWith(
+        'api/unified-search',
+        expect.objectContaining({ query: '*' })
+      );
+    });
+
+    it('should fetch stars from api/user/stars', async () => {
+      const fallback = createFallbackSearcher();
+      const searcher = new UnifiedSearcher(fallback);
+
+      mockBackendSrv.get.mockResolvedValue([]);
+
+      await searcher.starred({ query: 'test' });
+      expect(mockBackendSrv.get).toHaveBeenCalledWith('api/user/stars');
+    });
+  });
+
+  describe('tags', () => {
+    it('should return tag counts from the response', async () => {
+      const fallback = createFallbackSearcher();
+      const searcher = new UnifiedSearcher(fallback);
+
+      const tagFrame: DataFrameJSON = {
+        schema: {
+          name: 'Tags',
+          fields: [
+            { name: 'tag', type: 'string' as any },
+            { name: 'count', type: 'number' as any },
+          ],
+        },
+        data: {
+          values: [
+            ['production', 'staging'],
+            [5, 3],
+          ],
+        },
+      };
+      mockBackendSrv.post.mockResolvedValue(makeSearchResponse([tagFrame]));
+
+      const result = await searcher.tags({ query: 'test' });
+      expect(result).toEqual([
+        { term: 'production', count: 5 },
+        { term: 'staging', count: 3 },
+      ]);
+    });
+
+    it('should fall back when Loading frame is returned', async () => {
+      const fallback = createFallbackSearcher();
+      const searcher = new UnifiedSearcher(fallback);
+
+      const loadingFrame: DataFrameJSON = {
+        schema: { name: 'Loading', fields: [] },
+        data: { values: [] },
+      };
+      mockBackendSrv.post.mockResolvedValue(makeSearchResponse([loadingFrame]));
+
+      await searcher.tags({ query: 'test' });
+      expect(fallback.tags).toHaveBeenCalledWith({ query: 'test' });
+    });
+
+    it('should return empty array when no tag frame is found', async () => {
+      const fallback = createFallbackSearcher();
+      const searcher = new UnifiedSearcher(fallback);
+
+      const nonTagFrame: DataFrameJSON = {
+        schema: {
+          name: 'Other',
+          fields: [{ name: 'other', type: 'string' as any }],
+        },
+        data: { values: [[]] },
+      };
+      mockBackendSrv.post.mockResolvedValue(makeSearchResponse([nonTagFrame]));
+
+      const result = await searcher.tags({ query: 'test' });
+      expect(result).toEqual([]);
+    });
+
+    it('should post with facet tag and limit 1', async () => {
+      const fallback = createFallbackSearcher();
+      const searcher = new UnifiedSearcher(fallback);
+
+      const tagFrame: DataFrameJSON = {
+        schema: {
+          name: 'Tags',
+          fields: [
+            { name: 'tag', type: 'string' as any },
+            { name: 'count', type: 'number' as any },
+          ],
+        },
+        data: { values: [[], []] },
+      };
+      mockBackendSrv.post.mockResolvedValue(makeSearchResponse([tagFrame]));
+
+      await searcher.tags({ query: 'test' });
+      expect(mockBackendSrv.post).toHaveBeenCalledWith(
+        'api/unified-search',
+        expect.objectContaining({
+          facet: [{ field: 'tag' }],
+          limit: 1,
+        })
+      );
+    });
+  });
+
+  describe('getSortOptions', () => {
+    it('should return alphabetical sort options by default', async () => {
+      const fallback = createFallbackSearcher();
+      const searcher = new UnifiedSearcher(fallback);
+
+      const opts = await searcher.getSortOptions();
+      expect(opts).toEqual(
+        expect.arrayContaining([
+          { value: 'name_sort', label: 'Alphabetically (A-Z)' },
+          { value: '-name_sort', label: 'Alphabetically (Z-A)' },
+        ])
+      );
+    });
+
+    it('should only return 2 options when analytics is disabled', async () => {
+      const fallback = createFallbackSearcher();
+      const searcher = new UnifiedSearcher(fallback);
+
+      (config as any).licenseInfo.enabledFeatures.analytics = false;
+
+      const opts = await searcher.getSortOptions();
+      expect(opts).toHaveLength(2);
+    });
+
+    it('should include enterprise sort options when analytics is enabled', async () => {
+      const fallback = createFallbackSearcher();
+      const searcher = new UnifiedSearcher(fallback);
+
+      (config as any).licenseInfo.enabledFeatures.analytics = true;
+
+      const opts = await searcher.getSortOptions();
+      expect(opts.length).toBeGreaterThan(2);
+
+      const labels = opts.map((o: any) => o.label);
+      expect(labels).toContain('Views total (most)');
+      expect(labels).toContain('Views total (least)');
+      expect(labels).toContain('Views 30 days (most)');
+      expect(labels).toContain('Errors total (most)');
+      expect(labels).toContain('Created time (recent)');
+      expect(labels).toContain('Created time (oldest)');
+      expect(labels).toContain('Updated time (recent)');
+      expect(labels).toContain('Updated time (oldest)');
+
+      (config as any).licenseInfo.enabledFeatures.analytics = false;
+    });
+  });
+
+  describe('getFolderViewSort', () => {
+    it('should return "name_sort"', () => {
+      const fallback = createFallbackSearcher();
+      const searcher = new UnifiedSearcher(fallback);
+
+      expect(searcher.getFolderViewSort()).toBe('name_sort');
+    });
+  });
+
+  describe('doSearchQuery pagination', () => {
+    it('should report isItemLoaded correctly', async () => {
+      const fallback = createFallbackSearcher();
+      const searcher = new UnifiedSearcher(fallback);
+
+      mockBackendSrv.post.mockResolvedValue(makeSearchResponse([makeResultFrame('Query results', 1)]));
+
+      const result = await searcher.search({ query: 'test' });
+      expect(result.isItemLoaded(0)).toBe(true);
+      expect(result.isItemLoaded(1)).toBe(false);
+    });
+  });
+});
