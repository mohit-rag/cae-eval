@@ -0,0 +1,78 @@
+import { config } from '@grafana/runtime';
+
+import { getGrafanaSearcher } from './searcher';
+
+jest.mock('@grafana/runtime', () => {
+  const actual = jest.requireActual('@grafana/runtime');
+  return {
+    ...actual,
+    config: {
+      ...actual.config,
+      featureToggles: {},
+    },
+  };
+});
+
+jest.mock('./bluge', () => ({
+  BlugeSearcher: jest.fn().mockImplementation(() => ({ type: 'bluge' })),
+}));
+
+jest.mock('./sql', () => ({
+  SQLSearcher: jest.fn().mockImplementation(() => ({ type: 'sql' })),
+}));
+
+jest.mock('./frontend', () => ({
+  FrontendSearcher: jest.fn().mockImplementation((inner: any) => ({ type: 'frontend', inner })),
+}));
+
+jest.mock('./unified', () => ({
+  UnifiedSearcher: jest.fn().mockImplementation((fallback: any) => ({ type: 'unified', fallback })),
+}));
+
+describe('getGrafanaSearcher', () => {
+  beforeEach(() => {
+    jest.resetModules();
+    (config as any).featureToggles = {};
+  });
+
+  it('should return UnifiedSearcher when unifiedStorageSearch is enabled', () => {
+    jest.isolateModules(() => {
+      const { config: cfg } = require('@grafana/runtime');
+      cfg.featureToggles = { unifiedStorageSearch: true };
+
+      const { getGrafanaSearcher: getSearcher } = require('./searcher');
