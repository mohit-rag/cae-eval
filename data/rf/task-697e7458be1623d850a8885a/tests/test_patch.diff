+      const { config: cfg } = require('@grafana/runtime');
+      cfg.featureToggles = { panelTitleSearch: true };
+
+      const originalSearch = window.location.search;
+      Object.defineProperty(window, 'location', {
+        value: { ...window.location, search: '?do-frontend-query' },
+        writable: true,
+      });
+
+      const { getGrafanaSearcher: getSearcher } = require('./searcher');
+      const searcher = getSearcher();
