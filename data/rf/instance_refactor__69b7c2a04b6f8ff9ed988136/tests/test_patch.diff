+/**
+ * \test Test that AppLayerTransactionGetActiveDetectLog returns the minimum
+ *       of log_id and inspect_id when a logger is active.
+ */
+static int AppLayerParserTest03(void)
+{
+    AppLayerParserBackupParserTable();
+
+    int result = 0;
+    Flow f;
+    AppLayerParserState pstate;
+
+    memset(&f, 0, sizeof(f));
+    memset(&pstate, 0, sizeof(pstate));
+
+    f.proto = IPPROTO_TCP;
+    f.alproto = ALPROTO_TEST;
+    f.alparser = &pstate;
+
+    pstate.inspect_id[0] = 5;
+    pstate.inspect_id[1] = 3;
+    pstate.log_id = 4;
+
+    alp_ctx.ctxs[FlowGetProtoMapping(IPPROTO_TCP)][ALPROTO_TEST].logger = TRUE;
+
+    uint64_t tx_id = AppLayerTransactionGetActiveDetectLog(&f, STREAM_TOSERVER);
+    if (tx_id != 4) {
+        printf("TOSERVER with logger: expected 4, got %" PRIu64 ": ", tx_id);
+        goto end;
+    }
+
+    tx_id = AppLayerTransactionGetActiveDetectLog(&f, STREAM_TOCLIENT);
+    if (tx_id != 3) {
+        printf("TOCLIENT with logger: expected 3, got %" PRIu64 ": ", tx_id);
+        goto end;
+    }
+
+    result = 1;
+ end:
+    AppLayerParserRestoreParserTable();
+    return result;
+}
+
