+// TestSchedulerInitReturnsCleanupFunction verifies that Init returns a valid cleanup function
+// that can be called to stop VU metrics emission.
+func TestSchedulerInitReturnsCleanupFunction(t *testing.T) {
+	t.Parallel()
+	runner := &minirunner.MiniRunner{
+		Fn: func(_ context.Context, _ *lib.State, _ chan<- metrics.SampleContainer) error {
+			return nil
+		},
+	}
+
+	ctx, cancel := context.WithCancel(context.Background())
+	defer cancel()
+
+	opts, err := executor.DeriveScenariosFromShortcuts(lib.Options{
+		Iterations: null.IntFrom(1),
+		VUs:        null.IntFrom(1),
+	}.Apply(runner.GetOptions()), nil)
+	require.NoError(t, err)
+
+	testRunState := getTestRunState(t, getTestPreInitState(t), opts, runner)
+	execScheduler, err := execution.NewScheduler(testRunState)
+	require.NoError(t, err)
+
+	samples := make(chan metrics.SampleContainer, 100)
+	defer close(samples)
+
+	// Init should return a non-nil cleanup function
+	stopEmission, err := execScheduler.Init(ctx, samples)
+	require.NoError(t, err)
+	require.NotNil(t, stopEmission, "Init should return a non-nil cleanup function")
+
+	// Cleanup function should be callable without panic
+	stopEmission()
+}
+
+// TestSchedulerInitThenRun verifies the correct sequence of Init followed by Run.
+func TestSchedulerInitThenRun(t *testing.T) {
+	t.Parallel()
+	var iterationCount int64
+	runner := &minirunner.MiniRunner{
+		Fn: func(_ context.Context, _ *lib.State, _ chan<- metrics.SampleContainer) error {
+			atomic.AddInt64(&iterationCount, 1)
+			return nil
+		},
+	}
+
+	ctx, cancel := context.WithCancel(context.Background())
+	defer cancel()
+
+	opts, err := executor.DeriveScenariosFromShortcuts(lib.Options{
+		Iterations: null.IntFrom(5),
+		VUs:        null.IntFrom(1),
+	}.Apply(runner.GetOptions()), nil)
+	require.NoError(t, err)
+
+	testRunState := getTestRunState(t, getTestPreInitState(t), opts, runner)
+	execScheduler, err := execution.NewScheduler(testRunState)
+	require.NoError(t, err)
+
+	samples := make(chan metrics.SampleContainer, 100)
+	go func() {
+		for range samples {
+		}
+	}()
+
+	// First call Init
+	stopEmission, err := execScheduler.Init(ctx, samples)
+	require.NoError(t, err)
+
+	// Then call Run
+	err = execScheduler.Run(ctx, ctx, samples)
+	require.NoError(t, err)
+
+	// Cleanup
+	stopEmission()
+	close(samples)
+
+	// Verify iterations ran
+	assert.Equal(t, int64(5), atomic.LoadInt64(&iterationCount))
+}
+
+// TestSchedulerInitCleanupStopsMetricsEmission verifies that calling the cleanup function
+// returned by Init properly stops the VU metrics emission.
+func TestSchedulerInitCleanupStopsMetricsEmission(t *testing.T) {
+	t.Parallel()
+	runner := &minirunner.MiniRunner{
+		Fn: func(_ context.Context, _ *lib.State, _ chan<- metrics.SampleContainer) error {
+			return nil
+		},
+	}
+
+	ctx, cancel := context.WithCancel(context.Background())
+	defer cancel()
+
+	opts, err := executor.DeriveScenariosFromShortcuts(lib.Options{
+		Iterations: null.IntFrom(1),
+		VUs:        null.IntFrom(1),
+	}.Apply(runner.GetOptions()), nil)
+	require.NoError(t, err)
+
+	testRunState := getTestRunState(t, getTestPreInitState(t), opts, runner)
+	execScheduler, err := execution.NewScheduler(testRunState)
+	require.NoError(t, err)
+
+	samples := make(chan metrics.SampleContainer, 100)
+
+	stopEmission, err := execScheduler.Init(ctx, samples)
+	require.NoError(t, err)
+
+	// Call cleanup - this should stop metrics emission without blocking
+	done := make(chan struct{})
+	go func() {
+		stopEmission()
+		close(done)
+	}()
+
+	select {
+	case <-done:
+		// Success - cleanup completed
+	case <-time.After(5 * time.Second):
+		t.Fatal("Cleanup function blocked for too long")
+	}
+
+	close(samples)
+}
