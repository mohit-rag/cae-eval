+func TestSystemdInShutdownSignal(t *testing.T) {
+	content := readFile(t, "src/daemon/daemon-shutdown.c")
+	lines := strings.Split(content, "\n")
+	for i, line := range lines {
+		if strings.Contains(line, "service_signal_exit") {
+			end := i + 5
+			if end > len(lines) {
+				end = len(lines)
+			}
+			window := strings.Join(lines[i:end], "\n")
+			if strings.Contains(window, "SERVICE_SYSTEMD") {
+				return
+			}
+		}
+	}
+	t.Fatal("SERVICE_SYSTEMD not found in service_signal_exit call")
+}
+
