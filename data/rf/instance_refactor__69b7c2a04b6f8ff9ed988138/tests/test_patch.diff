+func TestSSLHasDedicatedTimingStep(t *testing.T) {
+	content := readFile(t, "src/daemon/main.c")
+	lines := strings.Split(content, "\n")
+	sslLine := -1
+	for i, line := range lines {
+		if strings.Contains(line, "netdata_conf_ssl()") {
+			sslLine = i
+			break
+		}
+	}
+	if sslLine < 0 {
+		t.Fatal("netdata_conf_ssl() not found")
+	}
+	start := sslLine - 5
+	if start < 0 {
+		start = 0
+	}
+	window := strings.Join(lines[start:sslLine+1], "\n")
+	if !strings.Contains(window, "delta_startup_time") {
+		t.Fatal("no delta_startup_time near netdata_conf_ssl()")
+	}
+	if strings.Contains(window, "initialize environment") {
+		t.Fatal("ssl timing still under monolithic 'initialize environment'")
+	}
+}
