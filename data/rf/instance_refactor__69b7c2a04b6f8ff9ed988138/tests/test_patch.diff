+func TestStatusFileVersionBumped(t *testing.T) {
+	content := readFile(t, "src/daemon/daemon-status-file.c")
+	re := regexp.MustCompile(`#define\s+STATUS_FILE_VERSION\s+(\d+)`)
+	m := re.FindStringSubmatch(content)
+	if m == nil {
+		t.Fatal("STATUS_FILE_VERSION not found")
+	}
+	version := 0
+	for _, c := range m[1] {
+		version = version*10 + int(c-'0')
+	}
+	if version <= 6 {
+		t.Fatalf("STATUS_FILE_VERSION is %d, expected > 6", version)
+	}
