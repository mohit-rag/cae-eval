+func TestBusNullCheckInLoop(t *testing.T) {
+	content := readFile(t, "src/daemon/daemon-systemd-watcher.c")
+	re1 := regexp.MustCompile(`while\s*\([^)]*service_running\s*\(\s*SERVICE_SYSTEMD\s*\)[^)]*bus[^)]*\)`)
+	re2 := regexp.MustCompile(`while\s*\([^)]*bus[^)]*service_running\s*\(\s*SERVICE_SYSTEMD\s*\)[^)]*\)`)
+	if !re1.MatchString(content) && !re2.MatchString(content) {
+		t.Fatal("bus null check not found in systemd watcher loop condition")
+	}
+}
