diff --git a/mysql-test/suite/innodb/t/thd_service_refactor.test b/mysql-test/suite/innodb/t/thd_service_refactor.test
new file mode 100644
index 00000000000..e5cbb350907
--- /dev/null
+++ b/mysql-test/suite/innodb/t/thd_service_refactor.test
@@ -0,0 +1,284 @@
+--source include/have_innodb.inc
+--source include/not_embedded.inc
+--source include/count_sessions.inc
+
+--echo #
+--echo # Verify that InnoDB transactions, foreign keys, MDL, INFORMATION_SCHEMA,
+--echo # strict mode, XA, and deadlock detection all produce correct results.
+--echo # Exercises the code paths where THD state is accessed in the storage
+--echo # engine layer.
+--echo #
+
+--echo #
+--echo # 1. Transaction modes: autocommit SELECT, explicit BEGIN, READ ONLY
+--echo #
+
+CREATE TABLE t_trx(a INT PRIMARY KEY) ENGINE=InnoDB;
+INSERT INTO t_trx VALUES (1),(2),(3);
+
+--echo # Autocommit SELECT (read-only autocommit path)
+SELECT * FROM t_trx;
+
+--echo # Explicit transaction
+BEGIN;
+INSERT INTO t_trx VALUES (4);
+SELECT * FROM t_trx;
+COMMIT;
+SELECT * FROM t_trx;
+
+--echo # Read-only transaction
+SET SESSION TRANSACTION READ ONLY;
+BEGIN;
+SELECT * FROM t_trx;
+COMMIT;
+SET SESSION TRANSACTION READ WRITE;
+
+--echo # Autocommit INSERT (read-write autocommit path)
+INSERT INTO t_trx VALUES (5);
+SELECT * FROM t_trx;
+
+DROP TABLE t_trx;
+
+--echo #
+--echo # 2. Foreign key enforcement with charset
+--echo #
+
+CREATE TABLE t_parent (
+  id INT PRIMARY KEY,
+  name VARCHAR(50)
+) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;
+
+CREATE TABLE t_child (
+  id INT PRIMARY KEY,
+  parent_id INT,
+  FOREIGN KEY (parent_id) REFERENCES t_parent(id)
+) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;
+
+INSERT INTO t_parent VALUES (1, 'one'), (2, 'two');
+INSERT INTO t_child VALUES (10, 1), (20, 2);
+
+--error ER_ROW_IS_REFERENCED_2
+DELETE FROM t_parent WHERE id = 1;
+
+--error ER_NO_REFERENCED_ROW_2
+INSERT INTO t_child VALUES (30, 999);
+
+DELETE FROM t_child WHERE id = 10;
+DELETE FROM t_parent WHERE id = 1;
+
+DROP TABLE t_child;
+DROP TABLE t_parent;
+
+--echo #
+--echo # 3. Strict mode FK validation
+--echo #
+
+SET @saved_strict = @@SESSION.sql_mode;
+SET SESSION sql_mode = 'STRICT_TRANS_TABLES';
+
+CREATE TABLE t_pk (id INT PRIMARY KEY) ENGINE=InnoDB;
+CREATE TABLE t_fk (
+  id INT PRIMARY KEY,
+  ref_id INT,
+  FOREIGN KEY (ref_id) REFERENCES t_pk(id)
+) ENGINE=InnoDB;
+
+INSERT INTO t_pk VALUES (1);
+INSERT INTO t_fk VALUES (1, 1);
+
+--error ER_NO_REFERENCED_ROW_2
+INSERT INTO t_fk VALUES (2, 99);
+
+DROP TABLE t_fk;
+DROP TABLE t_pk;
+
+SET SESSION sql_mode = @saved_strict;
+
+--echo #
+--echo # 4. Transaction rollback via lock wait timeout
+--echo #
+
+CREATE TABLE t_lock (a INT PRIMARY KEY) ENGINE=InnoDB;
+INSERT INTO t_lock VALUES (1);
+
+--connect (con_blocker,localhost,root,,)
+BEGIN;
+SELECT * FROM t_lock FOR UPDATE;
+
+--connection default
+SET @saved_timeout = @@SESSION.innodb_lock_wait_timeout;
+SET SESSION innodb_lock_wait_timeout = 1;
+BEGIN;
+--error ER_LOCK_WAIT_TIMEOUT
+SELECT * FROM t_lock FOR UPDATE;
+COMMIT;
+SET SESSION innodb_lock_wait_timeout = @saved_timeout;
+
+--connection con_blocker
+COMMIT;
+--disconnect con_blocker
+--connection default
+
+DROP TABLE t_lock;
+
+--echo #
+--echo # 5. INFORMATION_SCHEMA.INNODB_TRX during active transaction
+--echo #
+
+CREATE TABLE t_is(a INT PRIMARY KEY) ENGINE=InnoDB;
+INSERT INTO t_is VALUES (1);
+
+BEGIN;
+SELECT * FROM t_is;
+SELECT COUNT(*) > 0 AS has_trx FROM INFORMATION_SCHEMA.INNODB_TRX
+  WHERE trx_mysql_thread_id = CONNECTION_ID();
+COMMIT;
+
+DROP TABLE t_is;
+
+--echo #
+--echo # 6. DDL operations that acquire and release MDL
+--echo #
+
+CREATE TABLE t_mdl (a INT PRIMARY KEY) ENGINE=InnoDB;
+INSERT INTO t_mdl VALUES (1);
+
+ALTER TABLE t_mdl ADD COLUMN b INT DEFAULT 0;
+SELECT * FROM t_mdl;
+
+RENAME TABLE t_mdl TO t_mdl_renamed;
+SELECT * FROM t_mdl_renamed;
+
+DROP TABLE t_mdl_renamed;
+
+--echo #
+--echo # 7. XA transactions: prepare, commit, rollback
+--echo #
+
+CREATE TABLE t_xa (a INT PRIMARY KEY) ENGINE=InnoDB;
+
+XA START 'test_xid_1';
+INSERT INTO t_xa VALUES (1);
+XA END 'test_xid_1';
+XA PREPARE 'test_xid_1';
+XA COMMIT 'test_xid_1';
+
+SELECT * FROM t_xa;
+
+XA START 'test_xid_2';
+INSERT INTO t_xa VALUES (2);
+XA END 'test_xid_2';
+XA PREPARE 'test_xid_2';
+XA ROLLBACK 'test_xid_2';
+
+SELECT * FROM t_xa;
+
+DROP TABLE t_xa;
+
+--echo #
+--echo # 8. INSERT and INSERT ... SELECT
+--echo #
+
+CREATE TABLE t_ins_src (a INT PRIMARY KEY) ENGINE=InnoDB;
+CREATE TABLE t_ins_dst (a INT PRIMARY KEY) ENGINE=InnoDB;
+
+INSERT INTO t_ins_src VALUES (1),(2),(3);
+INSERT INTO t_ins_dst SELECT * FROM t_ins_src;
+SELECT * FROM t_ins_dst;
+
+DROP TABLE t_ins_dst;
+DROP TABLE t_ins_src;
+
+--echo #
+--echo # 9. Deadlock detection with mixed-engine transaction
+--echo #    One transaction has edited a non-transactional (MyISAM) table,
+--echo #    which influences the deadlock victim selection.
+--echo #
+
+CREATE TABLE t_myisam (a INT) ENGINE=MyISAM;
+CREATE TABLE t_dead1 (a INT PRIMARY KEY) ENGINE=InnoDB;
+INSERT INTO t_dead1 VALUES (1),(2);
+
+--connect (con_dead,localhost,root,,)
+
+--echo # con_dead: edit non-transactional table, then lock row 2
+--connection con_dead
+BEGIN;
+INSERT INTO t_myisam VALUES (1);
+SELECT * FROM t_dead1 WHERE a = 2 FOR UPDATE;
+
+--echo # default: lock row 1
+--connection default
+BEGIN;
+SELECT * FROM t_dead1 WHERE a = 1 FOR UPDATE;
+
+--echo # con_dead: try to lock row 1 (will block)
+--connection con_dead
+--send SELECT * FROM t_dead1 WHERE a = 1 FOR UPDATE
+
+--echo # default: wait for lock contention, then try row 2 (creates deadlock cycle)
+--connection default
+let $wait_condition=
+  SELECT COUNT(*) = 1 FROM INFORMATION_SCHEMA.INNODB_LOCK_WAITS;
+--source include/wait_condition.inc
+--error ER_LOCK_DEADLOCK
+SELECT * FROM t_dead1 WHERE a = 2 FOR UPDATE;
+ROLLBACK;
+
+--connection con_dead
+--reap
+COMMIT;
+--disconnect con_dead
+--connection default
+
+DROP TABLE t_dead1;
+DROP TABLE t_myisam;
+
+--echo #
+--echo # 10. Basic table open and read
+--echo #
+
+CREATE TABLE t_open (a INT PRIMARY KEY) ENGINE=InnoDB;
+INSERT INTO t_open VALUES (1),(2);
+SELECT * FROM t_open;
+DROP TABLE t_open;
+
+--echo #
+--echo # 11. ALTER TABLE ADD FOREIGN KEY under strict mode
+--echo #
+
+SET @saved_mode = @@SESSION.sql_mode;
+SET SESSION sql_mode = 'STRICT_TRANS_TABLES';
+
+CREATE TABLE t_alter_fk_parent (id INT PRIMARY KEY) ENGINE=InnoDB;
+CREATE TABLE t_alter_fk_child (
+  id INT PRIMARY KEY,
+  ref_id INT
+) ENGINE=InnoDB;
+
+INSERT INTO t_alter_fk_parent VALUES (1),(2);
+INSERT INTO t_alter_fk_child VALUES (1, 1),(2, 2);
+
+ALTER TABLE t_alter_fk_child ADD FOREIGN KEY (ref_id) REFERENCES t_alter_fk_parent(id);
+
+--error ER_NO_REFERENCED_ROW_2
+INSERT INTO t_alter_fk_child VALUES (3, 99);
+
+DROP TABLE t_alter_fk_child;
+DROP TABLE t_alter_fk_parent;
+
+SET SESSION sql_mode = @saved_mode;
+
+--echo #
+--echo # 12. Query visibility in INFORMATION_SCHEMA during active transaction
+--echo #
+
+CREATE TABLE t_qs (a INT PRIMARY KEY) ENGINE=InnoDB;
+BEGIN;
+INSERT INTO t_qs VALUES (1);
+SELECT trx_query IS NOT NULL AS has_query FROM INFORMATION_SCHEMA.INNODB_TRX
+  WHERE trx_mysql_thread_id = CONNECTION_ID();
+COMMIT;
+DROP TABLE t_qs;
+
+--source include/wait_until_count_sessions.inc
diff --git a/mysql-test/suite/innodb/r/thd_service_refactor.result b/mysql-test/suite/innodb/r/thd_service_refactor.result
