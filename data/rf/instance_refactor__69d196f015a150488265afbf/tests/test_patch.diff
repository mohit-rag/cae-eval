@@ -0,0 +1,259 @@
+#
+# Verify that InnoDB transactions, foreign keys, MDL, INFORMATION_SCHEMA,
+# strict mode, XA, and deadlock detection all produce correct results.
+# Exercises the code paths where THD state is accessed in the storage
+# engine layer.
+#
+#
+# 1. Transaction modes: autocommit SELECT, explicit BEGIN, READ ONLY
+#
+CREATE TABLE t_trx(a INT PRIMARY KEY) ENGINE=InnoDB;
+INSERT INTO t_trx VALUES (1),(2),(3);
+# Autocommit SELECT (read-only autocommit path)
+SELECT * FROM t_trx;
+a
+1
+2
+3
+# Explicit transaction
+BEGIN;
+INSERT INTO t_trx VALUES (4);
+SELECT * FROM t_trx;
+a
+1
+2
+3
+4
+COMMIT;
+SELECT * FROM t_trx;
+a
+1
+2
+3
+4
+# Read-only transaction
+SET SESSION TRANSACTION READ ONLY;
+BEGIN;
+SELECT * FROM t_trx;
+a
+1
+2
+3
+4
+COMMIT;
+SET SESSION TRANSACTION READ WRITE;
+# Autocommit INSERT (read-write autocommit path)
+INSERT INTO t_trx VALUES (5);
+SELECT * FROM t_trx;
+a
+1
+2
+3
+4
+5
+DROP TABLE t_trx;
+#
+# 2. Foreign key enforcement with charset
+#
+CREATE TABLE t_parent (
+id INT PRIMARY KEY,
+name VARCHAR(50)
+) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;
+CREATE TABLE t_child (
+id INT PRIMARY KEY,
+parent_id INT,
+FOREIGN KEY (parent_id) REFERENCES t_parent(id)
+) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;
+INSERT INTO t_parent VALUES (1, 'one'), (2, 'two');
+INSERT INTO t_child VALUES (10, 1), (20, 2);
+DELETE FROM t_parent WHERE id = 1;
+ERROR 23000: Cannot delete or update a parent row: a foreign key constraint fails (`test`.`t_child`, CONSTRAINT `t_child_ibfk_1` FOREIGN KEY (`parent_id`) REFERENCES `t_parent` (`id`))
+INSERT INTO t_child VALUES (30, 999);
+ERROR 23000: Cannot add or update a child row: a foreign key constraint fails (`test`.`t_child`, CONSTRAINT `t_child_ibfk_1` FOREIGN KEY (`parent_id`) REFERENCES `t_parent` (`id`))
+DELETE FROM t_child WHERE id = 10;
+DELETE FROM t_parent WHERE id = 1;
+DROP TABLE t_child;
+DROP TABLE t_parent;
+#
+# 3. Strict mode FK validation
+#
+SET @saved_strict = @@SESSION.sql_mode;
+SET SESSION sql_mode = 'STRICT_TRANS_TABLES';
+CREATE TABLE t_pk (id INT PRIMARY KEY) ENGINE=InnoDB;
+CREATE TABLE t_fk (
+id INT PRIMARY KEY,
+ref_id INT,
+FOREIGN KEY (ref_id) REFERENCES t_pk(id)
+) ENGINE=InnoDB;
+INSERT INTO t_pk VALUES (1);
+INSERT INTO t_fk VALUES (1, 1);
+INSERT INTO t_fk VALUES (2, 99);
+ERROR 23000: Cannot add or update a child row: a foreign key constraint fails (`test`.`t_fk`, CONSTRAINT `t_fk_ibfk_1` FOREIGN KEY (`ref_id`) REFERENCES `t_pk` (`id`))
+DROP TABLE t_fk;
+DROP TABLE t_pk;
+SET SESSION sql_mode = @saved_strict;
+#
+# 4. Transaction rollback via lock wait timeout
+#
+CREATE TABLE t_lock (a INT PRIMARY KEY) ENGINE=InnoDB;
+INSERT INTO t_lock VALUES (1);
+connect  con_blocker,localhost,root,,;
+BEGIN;
+SELECT * FROM t_lock FOR UPDATE;
+a
+1
+connection default;
+SET @saved_timeout = @@SESSION.innodb_lock_wait_timeout;
+SET SESSION innodb_lock_wait_timeout = 1;
+BEGIN;
+SELECT * FROM t_lock FOR UPDATE;
+ERROR HY000: Lock wait timeout exceeded; try restarting transaction
+COMMIT;
+SET SESSION innodb_lock_wait_timeout = @saved_timeout;
+connection con_blocker;
+COMMIT;
+disconnect con_blocker;
+connection default;
+DROP TABLE t_lock;
+#
+# 5. INFORMATION_SCHEMA.INNODB_TRX during active transaction
+#
+CREATE TABLE t_is(a INT PRIMARY KEY) ENGINE=InnoDB;
+INSERT INTO t_is VALUES (1);
+BEGIN;
+SELECT * FROM t_is;
+a
+1
+SELECT COUNT(*) > 0 AS has_trx FROM INFORMATION_SCHEMA.INNODB_TRX
+WHERE trx_mysql_thread_id = CONNECTION_ID();
+has_trx
+1
+COMMIT;
+DROP TABLE t_is;
+#
+# 6. DDL operations that acquire and release MDL
+#
+CREATE TABLE t_mdl (a INT PRIMARY KEY) ENGINE=InnoDB;
+INSERT INTO t_mdl VALUES (1);
+ALTER TABLE t_mdl ADD COLUMN b INT DEFAULT 0;
+SELECT * FROM t_mdl;
+a	b
+1	0
+RENAME TABLE t_mdl TO t_mdl_renamed;
+SELECT * FROM t_mdl_renamed;
+a	b
+1	0
+DROP TABLE t_mdl_renamed;
+#
+# 7. XA transactions: prepare, commit, rollback
+#
+CREATE TABLE t_xa (a INT PRIMARY KEY) ENGINE=InnoDB;
+XA START 'test_xid_1';
+INSERT INTO t_xa VALUES (1);
+XA END 'test_xid_1';
+XA PREPARE 'test_xid_1';
+XA COMMIT 'test_xid_1';
+SELECT * FROM t_xa;
+a
+1
+XA START 'test_xid_2';
+INSERT INTO t_xa VALUES (2);
+XA END 'test_xid_2';
+XA PREPARE 'test_xid_2';
+XA ROLLBACK 'test_xid_2';
+SELECT * FROM t_xa;
+a
+1
+DROP TABLE t_xa;
+#
+# 8. INSERT and INSERT ... SELECT
+#
+CREATE TABLE t_ins_src (a INT PRIMARY KEY) ENGINE=InnoDB;
+CREATE TABLE t_ins_dst (a INT PRIMARY KEY) ENGINE=InnoDB;
+INSERT INTO t_ins_src VALUES (1),(2),(3);
+INSERT INTO t_ins_dst SELECT * FROM t_ins_src;
+SELECT * FROM t_ins_dst;
+a
+1
+2
+3
+DROP TABLE t_ins_dst;
+DROP TABLE t_ins_src;
+#
+# 9. Deadlock detection with mixed-engine transaction
+#    One transaction has edited a non-transactional (MyISAM) table,
+#    which influences the deadlock victim selection.
+#
+CREATE TABLE t_myisam (a INT) ENGINE=MyISAM;
+CREATE TABLE t_dead1 (a INT PRIMARY KEY) ENGINE=InnoDB;
+INSERT INTO t_dead1 VALUES (1),(2);
+connect  con_dead,localhost,root,,;
+# con_dead: edit non-transactional table, then lock row 2
+connection con_dead;
+BEGIN;
+INSERT INTO t_myisam VALUES (1);
+SELECT * FROM t_dead1 WHERE a = 2 FOR UPDATE;
+a
+2
+# default: lock row 1
+connection default;
+BEGIN;
+SELECT * FROM t_dead1 WHERE a = 1 FOR UPDATE;
+a
+1
+# con_dead: try to lock row 1 (will block)
+connection con_dead;
+SELECT * FROM t_dead1 WHERE a = 1 FOR UPDATE;
+# default: wait for lock contention, then try row 2 (creates deadlock cycle)
+connection default;
+SELECT * FROM t_dead1 WHERE a = 2 FOR UPDATE;
+ERROR 40001: Deadlock found when trying to get lock; try restarting transaction
+ROLLBACK;
+connection con_dead;
+a
+1
+COMMIT;
+disconnect con_dead;
+connection default;
+DROP TABLE t_dead1;
+DROP TABLE t_myisam;
+#
+# 10. Basic table open and read
+#
+CREATE TABLE t_open (a INT PRIMARY KEY) ENGINE=InnoDB;
+INSERT INTO t_open VALUES (1),(2);
+SELECT * FROM t_open;
+a
+1
+2
+DROP TABLE t_open;
+#
+# 11. ALTER TABLE ADD FOREIGN KEY under strict mode
+#
+SET @saved_mode = @@SESSION.sql_mode;
+SET SESSION sql_mode = 'STRICT_TRANS_TABLES';
+CREATE TABLE t_alter_fk_parent (id INT PRIMARY KEY) ENGINE=InnoDB;
+CREATE TABLE t_alter_fk_child (
+id INT PRIMARY KEY,
+ref_id INT
+) ENGINE=InnoDB;
+INSERT INTO t_alter_fk_parent VALUES (1),(2);
+INSERT INTO t_alter_fk_child VALUES (1, 1),(2, 2);
+ALTER TABLE t_alter_fk_child ADD FOREIGN KEY (ref_id) REFERENCES t_alter_fk_parent(id);
+INSERT INTO t_alter_fk_child VALUES (3, 99);
+ERROR 23000: Cannot add or update a child row: a foreign key constraint fails (`test`.`t_alter_fk_child`, CONSTRAINT `t_alter_fk_child_ibfk_1` FOREIGN KEY (`ref_id`) REFERENCES `t_alter_fk_parent` (`id`))
+DROP TABLE t_alter_fk_child;
+DROP TABLE t_alter_fk_parent;
+SET SESSION sql_mode = @saved_mode;
+#
+# 12. Query visibility in INFORMATION_SCHEMA during active transaction
+#
+CREATE TABLE t_qs (a INT PRIMARY KEY) ENGINE=InnoDB;
+BEGIN;
+INSERT INTO t_qs VALUES (1);
+SELECT trx_query IS NOT NULL AS has_query FROM INFORMATION_SCHEMA.INNODB_TRX
+WHERE trx_mysql_thread_id = CONNECTION_ID();
+has_query
+1
+COMMIT;
+DROP TABLE t_qs;
