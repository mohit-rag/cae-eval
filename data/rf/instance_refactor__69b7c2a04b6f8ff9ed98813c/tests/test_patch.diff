diff --git a/src/libnetdata/os/tests/test_get_system_pagesize.c b/src/libnetdata/os/tests/test_get_system_pagesize.c
new file mode 100644
index 000000000..b4faee67a
--- /dev/null
+++ b/src/libnetdata/os/tests/test_get_system_pagesize.c
@@ -0,0 +1,57 @@
+// SPDX-License-Identifier: GPL-3.0-or-later
+
+#include "../../libnetdata.h"
+#include "../../required_dummies.h"
+#include <setjmp.h>
+#include <cmocka.h>
+
+static void test_page_size_is_at_least_4096(void **state) {
+    (void)state;
+    size_t page_size = os_get_system_page_size();
+    assert_true(page_size >= 4096);
+}
+
+static void test_page_size_is_power_of_two(void **state) {
+    (void)state;
+    size_t page_size = os_get_system_page_size();
+    assert_true(page_size > 0);
+    assert_int_equal(page_size & (page_size - 1), 0);
+}
+
+static void test_page_size_is_consistent(void **state) {
+    (void)state;
+    size_t first = os_get_system_page_size();
+    size_t second = os_get_system_page_size();
+    size_t third = os_get_system_page_size();
+    assert_int_equal(first, second);
+    assert_int_equal(second, third);
+}
+
+static void test_page_size_matches_sysconf(void **state) {
+    (void)state;
+    size_t our_size = os_get_system_page_size();
+    long sys_size = sysconf(_SC_PAGE_SIZE);
+    if (sys_size > 4096) {
+        assert_int_equal(our_size, (size_t)sys_size);
+    } else {
+        assert_int_equal(our_size, 4096);
+    }
+}
+
+static void test_page_size_reasonable_upper_bound(void **state) {
+    (void)state;
+    size_t page_size = os_get_system_page_size();
+    assert_true(page_size <= 1024 * 1024);
+}
+
+int main(void) {
+    const struct CMUnitTest tests[] = {
+        cmocka_unit_test(test_page_size_is_at_least_4096),
+        cmocka_unit_test(test_page_size_is_power_of_two),
+        cmocka_unit_test(test_page_size_is_consistent),
+        cmocka_unit_test(test_page_size_matches_sysconf),
+        cmocka_unit_test(test_page_size_reasonable_upper_bound),
+    };
+
+    return cmocka_run_group_tests_name("os_get_system_page_size", tests, NULL, NULL);
+}
