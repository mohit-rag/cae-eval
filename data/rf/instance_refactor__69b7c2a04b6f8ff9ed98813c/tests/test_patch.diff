+    void *ptr = nd_mmap_advanced(NULL, 4096, MAP_PRIVATE, 1, false, false, NULL);
+    assert_non_null(ptr);
+    nd_munmap(ptr, 4096);
+
+    enable_ksm = saved_ksm;
+}
+
+int main(void) {
