+        cmocka_unit_test(test_nd_mmap_advanced_updates_counters),
+        cmocka_unit_test(test_nd_mmap_advanced_large_allocation),
+        cmocka_unit_test(test_nd_mmap_advanced_dont_dump),
+        cmocka_unit_test(test_madvise_sequential_on_valid_mapping),
+        cmocka_unit_test(test_madvise_random_on_valid_mapping),
+        cmocka_unit_test(test_madvise_willneed_on_valid_mapping),
+        cmocka_unit_test(test_madvise_dontneed_on_valid_mapping),
+        cmocka_unit_test(test_madvise_dontfork_on_valid_mapping),
+        cmocka_unit_test(test_madvise_dontdump_on_valid_mapping),
+        cmocka_unit_test(test_madvise_mergeable_on_valid_mapping),
+        cmocka_unit_test(test_nd_mmap_advanced_file_backed_shared),
+        cmocka_unit_test(test_nd_mmap_advanced_file_backed_read_only),
