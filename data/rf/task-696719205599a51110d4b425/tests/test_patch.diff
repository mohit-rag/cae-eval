+jest.mock( '@automattic/api-queries', () => ( {
+	sitePluginActivateMutation: jest.fn( () => ( { mutationFn: jest.fn() } ) ),
+	sitePluginDeactivateMutation: jest.fn( () => ( { mutationFn: jest.fn() } ) ),
+	sitePluginAutoupdateDisableMutation: jest.fn( () => ( { mutationFn: jest.fn() } ) ),
+	sitePluginAutoupdateEnableMutation: jest.fn( () => ( { mutationFn: jest.fn() } ) ),
+	sitePluginRemoveMutation: jest.fn( () => ( { mutationFn: jest.fn() } ) ),
+	sitePluginUpdateMutation: jest.fn( () => ( { mutationFn: jest.fn() } ) ),
+	invalidatePlugins: jest.fn(),
+	resetPlugins: jest.fn(),
+} ) );
+
+jest.mock( '@tanstack/react-query', () => ( {
+	useMutation: jest.fn( () => ( { mutateAsync: mockMutateAsync } ) ),
+} ) );
+
+jest.mock( '@wordpress/dataviews', () => {
+	const React = require( 'react' );
+	return {
+		DataViews: jest.fn( ( props: any ) =>
+			React.createElement(
+				'div',
+				{ 'data-testid': 'dataviews' },
+				props.actions?.map( ( action: any ) =>
+					action.RenderModal
+						? React.createElement( action.RenderModal, {
+								key: action.id,
+								items: [],
+								closeModal: jest.fn(),
+						  } )
