@@ -0,0 +1,97 @@
+jest.mock( '@automattic/api-core', () => ( {
+	deactivateSitePlugin: jest.fn().mockResolvedValue( {} ),
+	disableSitePluginAutoupdate: jest.fn().mockResolvedValue( {} ),
+	removeSitePlugin: jest.fn().mockResolvedValue( {} ),
+	activateSitePlugin: jest.fn(),
+	updateSitePlugin: jest.fn(),
+	enableSitePluginAutoupdate: jest.fn(),
+	installSitePlugin: jest.fn(),
+	fetchUserSitesPlugins: jest.fn(),
+	fetchSitePlugins: jest.fn(),
+	fetchSiteCorePlugins: jest.fn(),
+	fetchSitePlugin: jest.fn(),
+} ) );
+
+jest.mock( '../query-client', () => ( {
+	queryClient: {
+		invalidateQueries: jest.fn(),
+		resetQueries: jest.fn(),
+	},
+} ) );
+
+import {
+	sitePluginDeactivateMutation,
+	sitePluginAutoupdateDisableMutation,
+	sitePluginRemoveMutation,
+} from '../site-plugins';
+import { queryClient } from '../query-client';
+
+beforeEach( () => {
+	jest.clearAllMocks();
+} );
+
+describe( 'sitePluginDeactivateMutation', () => {
+	it( 'invalidates queries on success by default', () => {
+		const options = sitePluginDeactivateMutation();
+		options.onSuccess!( {}, { siteId: 123 }, undefined as any );
+		expect( queryClient.invalidateQueries ).toHaveBeenCalled();
+	} );
+
+	it( 'supports suppressing query invalidation on success', () => {
+		const options = sitePluginDeactivateMutation( false );
+		if ( options.onSuccess ) {
+			options.onSuccess( {}, { siteId: 123 }, undefined as any );
+		}
+		expect( queryClient.invalidateQueries ).not.toHaveBeenCalled();
+	} );
+
+	it( 'invalidates queries when explicitly passed true', () => {
+		const options = sitePluginDeactivateMutation( true );
+		options.onSuccess!( {}, { siteId: 123 }, undefined as any );
+		expect( queryClient.invalidateQueries ).toHaveBeenCalled();
+	} );
+} );
+
+describe( 'sitePluginAutoupdateDisableMutation', () => {
+	it( 'invalidates queries on success by default', () => {
+		const options = sitePluginAutoupdateDisableMutation();
+		options.onSuccess!( {}, { siteId: 789 }, undefined as any );
+		expect( queryClient.invalidateQueries ).toHaveBeenCalled();
+	} );
+
+	it( 'supports suppressing query invalidation on success', () => {
+		const options = sitePluginAutoupdateDisableMutation( false );
+		if ( options.onSuccess ) {
+			options.onSuccess( {}, { siteId: 789 }, undefined as any );
+		}
+		expect( queryClient.invalidateQueries ).not.toHaveBeenCalled();
+	} );
+
+	it( 'invalidates queries when explicitly passed true', () => {
+		const options = sitePluginAutoupdateDisableMutation( true );
+		options.onSuccess!( {}, { siteId: 789 }, undefined as any );
+		expect( queryClient.invalidateQueries ).toHaveBeenCalled();
+	} );
+} );
+
+describe( 'sitePluginRemoveMutation', () => {
+	it( 'invalidates queries on success by default', () => {
+		const options = sitePluginRemoveMutation();
+		options.onSuccess!( {}, { siteId: 321 }, undefined as any );
+		expect( queryClient.invalidateQueries ).toHaveBeenCalled();
+	} );
+
+	it( 'supports suppressing query invalidation on success', () => {
+		const options = sitePluginRemoveMutation( false );
+		if ( options.onSuccess ) {
+			options.onSuccess( {}, { siteId: 321 }, undefined as any );
+		}
+		expect( queryClient.invalidateQueries ).not.toHaveBeenCalled();
+	} );
+
+	it( 'invalidates queries when explicitly passed true', () => {
+		const options = sitePluginRemoveMutation( true );
+		options.onSuccess!( {}, { siteId: 321 }, undefined as any );
+		expect( queryClient.invalidateQueries ).toHaveBeenCalled();
+	} );
+} );
