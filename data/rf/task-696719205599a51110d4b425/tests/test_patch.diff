+				)
+			)
+		),
+		filterSortAndPaginate: jest.fn( () => ( { data: [], paginationInfo: {} } ) ),
+	};
+} );
+
+jest.mock( '../../manage/components/action-render-modal', () => ( {
+	__esModule: true,
+	default: () => null,
+	getModalHeader: jest.fn( () => 'Header' ),
+} ) );
+
+jest.mock( '../../manage/components/plugins-header-actions', () => ( {
+	PluginsHeaderActions: () => null,
+} ) );
+
+jest.mock( '../../manage/utils', () => ( {
+	buildBulkSitesPluginAction: jest.fn( () => jest.fn() ),
+} ) );
+
+jest.mock( '../../utils/update-filters', () => ( {
+	getViewFilteredByUpdates: jest.fn(),
+} ) );
+
+jest.mock( '../components/action-render-modal-wrapper', () => ( {
+	ActionRenderModalWrapper: () => null,
+} ) );
+
+jest.mock( '../components/active-toggle', () => ( { ActiveToggle: () => null } ) );
+jest.mock( '../components/autoupdate-toggle', () => ( { AutoupdateToggle: () => null } ) );
+jest.mock( '../components/plugin-site-field-content', () => ( {
+	PluginSiteFieldContent: () => null,
+} ) );
+
+jest.mock( '../../../utils/site-name', () => ( {
+	getSiteDisplayName: jest.fn( () => 'Test Site' ),
+} ) );
+
+jest.mock( '../../../utils/site-url', () => ( {
+	getSiteDisplayUrl: jest.fn( () => 'test.example.com' ),
+} ) );
+
+jest.mock( '../utils/get-allowed-plugin-actions', () => ( {
+	getAllowedPluginActions: jest.fn( () => ( { autoupdate: true, isManagedPlugin: false } ) ),
+} ) );
+
+jest.mock( '../utils/map-to-plugin-list-row', () => ( {
+	mapToPluginListRow: jest.fn( () => ( { id: 'test-plugin', siteIds: [] } ) ),
+} ) );
+
+import { render, screen } from '@testing-library/react';
+import { SitesWithThisPlugin } from '../sites-with-this-plugin';
+import {
+	sitePluginDeactivateMutation,
+	sitePluginAutoupdateDisableMutation,
+	sitePluginRemoveMutation,
+} from '@automattic/api-queries';
+import { buildBulkSitesPluginAction } from '../../manage/utils';
+
+const defaultProps = {
+	pluginSlug: 'test-plugin',
+	isLoading: false,
+	plugin: undefined,
+	pluginBySiteId: new Map(),
+	setOptimisticDelete: jest.fn(),
+	sitesWithThisPlugin: [],
+};
+
+describe( 'SitesWithThisPlugin', () => {
+	beforeEach( () => {
+		jest.clearAllMocks();
+	} );
+
+	it( 'renders the component with plugin data views', () => {
+		render( <SitesWithThisPlugin { ...defaultProps } /> );
+		expect( screen.getByTestId( 'dataviews' ) ).toBeInTheDocument();
+	} );
+
+	it( 'initializes bulk action handlers from mutation hooks', () => {
+		render( <SitesWithThisPlugin { ...defaultProps } /> );
+		expect( buildBulkSitesPluginAction ).toHaveBeenCalled();
+	} );
+
+	it( 'configures delete modal mutations with query invalidation suppressed', () => {
+		render( <SitesWithThisPlugin { ...defaultProps } /> );
+		expect( sitePluginDeactivateMutation ).toHaveBeenCalledWith( false );
+		expect( sitePluginAutoupdateDisableMutation ).toHaveBeenCalledWith( false );
+		expect( sitePluginRemoveMutation ).toHaveBeenCalledWith( false );
+	} );
+} );
