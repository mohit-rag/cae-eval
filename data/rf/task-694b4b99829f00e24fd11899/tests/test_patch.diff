+
+def test_update_alias_mailbox_ids_with_empty_list_returns_error(flask_client):
+    """
+    Prompt requirement: API responses should stay the same.
+    Verify empty mailbox_ids returns 400 with appropriate error message.
+    """
+    user, api_key = get_new_user_and_api_key()
+    alias = Alias.create_new_random(user)
+    Session.commit()
+
+    r = flask_client.put(
+        url_for("api.update_alias", alias_id=alias.id),
+        headers={"Authentication": api_key.code},
+        json={"mailbox_ids": []},
+    )
+
+    assert r.status_code == 400
+    assert r.json["error"] == "Must choose at least one mailbox"
+
+
+def test_update_alias_mailbox_ids_with_other_user_mailbox_returns_forbidden(flask_client):
+    """
+    Prompt requirement: API responses should stay the same.
+    Verify using another user's mailbox returns 400 with Forbidden error.
+    """
+    user, api_key = get_new_user_and_api_key()
+    other_user, _ = get_new_user_and_api_key()
+    alias = Alias.create_new_random(user)
+    Session.commit()
+
+    r = flask_client.put(
+        url_for("api.update_alias", alias_id=alias.id),
+        headers={"Authentication": api_key.code},
+        json={"mailbox_ids": [other_user.default_mailbox_id]},
+    )
+
+    assert r.status_code == 400
+    assert r.json["error"] == "Forbidden"
+
+
+def test_update_alias_mailbox_ids_with_valid_mailboxes_succeeds(flask_client):
+    """
+    Prompt requirement: API responses should stay the same.
+    Verify valid mailbox assignment succeeds and updates the alias.
+    """
+    user, api_key = get_new_user_and_api_key()
+    alias = Alias.create_new_random(user)
+    mb = Mailbox.create(user_id=user.id, email="new@test.com", verified=True)
+    Session.commit()
+
+    r = flask_client.put(
+        url_for("api.update_alias", alias_id=alias.id),
+        headers={"Authentication": api_key.code},
+        json={"mailbox_ids": [mb.id]},
+    )
+
+    assert r.status_code == 200
+    alias = Alias.get(alias.id)
+    assert alias.mailbox_id == mb.id
+
+
+def test_update_alias_mailbox_ids_with_unverified_mailbox_returns_forbidden(flask_client):
+    """
+    Prompt requirement: API responses should stay the same.
+    Verify unverified mailbox returns 400 with Forbidden error.
+    """
+    user, api_key = get_new_user_and_api_key()
+    alias = Alias.create_new_random(user)
+    unverified_mb = Mailbox.create(user_id=user.id, email="unverified@test.com", verified=False)
+    Session.commit()
+
+    r = flask_client.put(
+        url_for("api.update_alias", alias_id=alias.id),
+        headers={"Authentication": api_key.code},
+        json={"mailbox_ids": [unverified_mb.id]},
+    )
+
+    assert r.status_code == 400
+    assert r.json["error"] == "Forbidden"
