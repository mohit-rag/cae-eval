+func TestListGroupProjectOptionsWithPagination(t *testing.T) {
+	const (
+		orderBy         = "last_activity_at"
+		paginationLimit = 100
+	)
+	listOpts := gogitlab.ListOptions{PerPage: paginationLimit}
+
+	listGroupProjectOptions := &gogitlab.ListGroupProjectsOptions{
+		ListOptions:      listOpts,
+		OrderBy:          gogitlab.String(orderBy),
+		IncludeSubGroups: gogitlab.Bool(true),
+	}
+
+	assert.Equal(t, 100, listGroupProjectOptions.ListOptions.PerPage)
+	assert.Equal(t, "last_activity_at", *listGroupProjectOptions.OrderBy)
+	assert.True(t, *listGroupProjectOptions.IncludeSubGroups)
+}
