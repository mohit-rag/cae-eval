+func TestPaginationConstants(t *testing.T) {
+	const (
+		orderBy         = "last_activity_at"
+		paginationLimit = 100
+	)
+
+	assert.Equal(t, "last_activity_at", orderBy, "orderBy constant should be 'last_activity_at'")
+	assert.Equal(t, 100, paginationLimit, "paginationLimit should be 100 (max allowed by GitLab API)")
+
+	listOpts := gogitlab.ListOptions{PerPage: paginationLimit}
+	assert.Equal(t, 100, listOpts.PerPage)
+
+	projectQueryOptions := &gogitlab.ListProjectsOptions{
+		OrderBy:     gogitlab.String(orderBy),
+		ListOptions: listOpts,
+	}
+	assert.Equal(t, "last_activity_at", *projectQueryOptions.OrderBy)
+	assert.Equal(t, 100, projectQueryOptions.ListOptions.PerPage)
+}
+
+func TestCloudBaseURLConditional(t *testing.T) {
+	tests := []struct {
+		name             string
+		sourceURL        string
+		wantAllAvailable bool
+	}{
+		{
+			name:             "gitlab.com cloud URL",
+			sourceURL:        "https://gitlab.com/",
+			wantAllAvailable: false,
+		},
+		{
+			name:             "self-hosted GitLab",
+			sourceURL:        "https://gitlab.mycompany.com/",
+			wantAllAvailable: true,
+		},
+		{
+			name:             "another self-hosted instance",
+			sourceURL:        "https://git.example.org/",
+			wantAllAvailable: true,
+		},
+	}
+
+	const cloudBaseURL = "https://gitlab.com/"
+
+	for _, tt := range tests {
+		t.Run(tt.name, func(t *testing.T) {
+			listGroupsOptions := gogitlab.ListGroupsOptions{
+				AllAvailable: gogitlab.Bool(false),
+				TopLevelOnly: gogitlab.Bool(false),
+				Owned:        gogitlab.Bool(false),
+			}
+
+			if tt.sourceURL != cloudBaseURL {
+				listGroupsOptions.AllAvailable = gogitlab.Bool(true)
+			}
+
+			assert.Equal(t, tt.wantAllAvailable, *listGroupsOptions.AllAvailable)
+		})
+	}
+}
+
+func TestErrorWrappingFormat(t *testing.T) {
+	baseErr := errors.New("connection refused")
+	authMethod := "token"
+
+	wrappedErr := fmt.Errorf("unable to authenticate using %s, %w", authMethod, baseErr)
+
+	assert.Contains(t, wrappedErr.Error(), "unable to authenticate using token")
+	assert.Contains(t, wrappedErr.Error(), "connection refused")
+	assert.True(t, errors.Is(wrappedErr, baseErr), "wrapped error should unwrap to base error")
+}
