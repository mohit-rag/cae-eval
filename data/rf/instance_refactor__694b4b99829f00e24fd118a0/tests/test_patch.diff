+func TestProcessProjectsDeduplication(t *testing.T) {
+	tests := []struct {
+		name           string
+		inputProjects  [][]*gogitlab.Project
+		wantCount      int
+		wantNamespaces []string
+	}{
+		{
+			name: "no duplicates",
+			inputProjects: [][]*gogitlab.Project{
+				{
+					{ID: 1, NameWithNamespace: "org/project1"},
+					{ID: 2, NameWithNamespace: "org/project2"},
+				},
+			},
+			wantCount:      2,
+			wantNamespaces: []string{"org/project1", "org/project2"},
+		},
+		{
+			name: "with duplicates in same batch",
+			inputProjects: [][]*gogitlab.Project{
+				{
+					{ID: 1, NameWithNamespace: "org/project1"},
+					{ID: 1, NameWithNamespace: "org/project1"},
+					{ID: 2, NameWithNamespace: "org/project2"},
+				},
+			},
+			wantCount:      2,
+			wantNamespaces: []string{"org/project1", "org/project2"},
+		},
+		{
+			name: "with duplicates across batches",
+			inputProjects: [][]*gogitlab.Project{
+				{
+					{ID: 1, NameWithNamespace: "org/project1"},
+					{ID: 2, NameWithNamespace: "org/project2"},
+				},
+				{
+					{ID: 2, NameWithNamespace: "org/project2"},
+					{ID: 3, NameWithNamespace: "org/project3"},
+				},
+			},
+			wantCount:      3,
+			wantNamespaces: []string{"org/project1", "org/project2", "org/project3"},
+		},
+		{
+			name: "all duplicates",
+			inputProjects: [][]*gogitlab.Project{
+				{
+					{ID: 1, NameWithNamespace: "org/project1"},
+				},
+				{
+					{ID: 1, NameWithNamespace: "org/project1"},
+				},
+				{
+					{ID: 1, NameWithNamespace: "org/project1"},
+				},
+			},
+			wantCount:      1,
+			wantNamespaces: []string{"org/project1"},
+		},
+		{
+			name:           "empty input",
+			inputProjects:  [][]*gogitlab.Project{},
+			wantCount:      0,
+			wantNamespaces: []string{},
+		},
+	}
+
+	for _, tt := range tests {
+		t.Run(tt.name, func(t *testing.T) {
+			uniqueProjects := make(map[int]*gogitlab.Project)
+			var projects []*gogitlab.Project
+			var projectsWithNamespace []string
+
+			processProjects := func(projList []*gogitlab.Project) {
+				for _, proj := range projList {
+					if _, exists := uniqueProjects[proj.ID]; !exists {
+						uniqueProjects[proj.ID] = proj
+						projects = append(projects, proj)
+						projectsWithNamespace = append(projectsWithNamespace, proj.NameWithNamespace)
+					}
+				}
+			}
+
+			for _, batch := range tt.inputProjects {
+				processProjects(batch)
+			}
+
+			assert.Equal(t, tt.wantCount, len(projects))
+			if tt.wantCount > 0 {
+				for _, ns := range tt.wantNamespaces {
+					assert.Contains(t, projectsWithNamespace, ns)
+				}
+			}
+		})
+	}
+}
