@@ -0,0 +1,133 @@
+import arrow
+
+from app import config
+from app.db import Session
+from app.events.event_dispatcher import EventDispatcher, GlobalDispatcher
+from app.events.generated import event_pb2
+from app.events.generated.event_pb2 import UserPlanChanged, EventContent
+from app.models import PartnerUser, Subscription, ManualSubscription
+from tests.utils import create_partner_linked_user, random_token
+
+
+class OnMemoryDispatcher:
+    def __init__(self):
+        self.memory = []
+
+    def send(self, event: bytes):
+        self.memory.append(event)
+
+    def clear(self):
+        self.memory = []
+
+
+on_memory_dispatcher = OnMemoryDispatcher()
+
+
+def setup_module():
+    GlobalDispatcher.set_dispatcher(on_memory_dispatcher)
+    config.EVENT_WEBHOOK = "http://test"
+
+
+def teardown_module():
+    GlobalDispatcher.set_dispatcher(None)
+    config.EVENT_WEBHOOK = None
+
+
+def setup_function(func):
+    on_memory_dispatcher.clear()
+
+
+def _dispatch_plan_change_for_user(user, partner_user):
+    """Replicate the per-user logic from send_plan_change_events.py"""
+    subscription_end = user.get_active_subscription_end(
+        include_partner_subscription=False
+    )
+    end_timestamp = None
+    if subscription_end:
+        end_timestamp = subscription_end.timestamp
+    event = UserPlanChanged(plan_end_time=end_timestamp)
+    EventDispatcher.send_event(
+        partner_user.user, EventContent(user_plan_change=event)
+    )
+    Session.flush()
+
+
+def _get_plan_change_event(data: bytes, user, pu) -> UserPlanChanged:
+    event = event_pb2.Event()
+    event.ParseFromString(data)
+    assert event.user_id == user.id
+    assert event.external_user_id == pu.external_user_id
+    assert event.partner_id == pu.partner_id
+    return event.content.user_plan_change
+
+
+def test_plan_change_event_for_user_without_subscription():
+    user, pu = create_partner_linked_user()
+    _dispatch_plan_change_for_user(user, pu)
+    assert len(on_memory_dispatcher.memory) == 1
+    plan_change = _get_plan_change_event(on_memory_dispatcher.memory[0], user, pu)
+    assert plan_change.plan_end_time == 0
+
+
+def test_plan_change_event_for_user_with_subscription():
+    user, pu = create_partner_linked_user()
+    end_at = arrow.utcnow().shift(days=1).replace(hour=0, minute=0, second=0)
+    Subscription.create(
+        user_id=user.id,
+        cancel_url="",
+        update_url="",
+        subscription_id=random_token(10),
+        event_time=arrow.now(),
+        next_bill_date=end_at.date(),
+        plan="yearly",
+        flush=True,
+    )
+    _dispatch_plan_change_for_user(user, pu)
+    assert len(on_memory_dispatcher.memory) == 1
+    plan_change = _get_plan_change_event(on_memory_dispatcher.memory[0], user, pu)
+    assert plan_change.plan_end_time == end_at.timestamp
+
+
+def test_plan_change_event_for_user_with_manual_subscription():
+    user, pu = create_partner_linked_user()
+    end_at = arrow.utcnow().shift(days=3).replace(hour=0, minute=0, second=0)
+    ManualSubscription.create(
+        user_id=user.id, end_at=end_at.date().strftime("%Y-%m-%d"), flush=True
+    )
+    _dispatch_plan_change_for_user(user, pu)
+    assert len(on_memory_dispatcher.memory) == 1
+    plan_change = _get_plan_change_event(on_memory_dispatcher.memory[0], user, pu)
+    assert plan_change.plan_end_time == end_at.timestamp
+
+
+def test_plan_change_dispatches_for_multiple_partner_users():
+    user1, pu1 = create_partner_linked_user()
+    user2, pu2 = create_partner_linked_user()
+    _dispatch_plan_change_for_user(user1, pu1)
+    _dispatch_plan_change_for_user(user2, pu2)
+    assert len(on_memory_dispatcher.memory) == 2
+    plan_change1 = _get_plan_change_event(on_memory_dispatcher.memory[0], user1, pu1)
+    plan_change2 = _get_plan_change_event(on_memory_dispatcher.memory[1], user2, pu2)
+    assert plan_change1.plan_end_time == 0
+    assert plan_change2.plan_end_time == 0
+
+
+def test_plan_change_event_contains_correct_partner_user_info():
+    user, pu = create_partner_linked_user()
+    _dispatch_plan_change_for_user(user, pu)
+    assert len(on_memory_dispatcher.memory) == 1
+    event = event_pb2.Event()
+    event.ParseFromString(on_memory_dispatcher.memory[0])
+    assert event.user_id == user.id
+    assert event.external_user_id == pu.external_user_id
+    assert event.partner_id == pu.partner_id
+    assert event.content.HasField("user_plan_change")
+
+
+def test_plan_change_excludes_partner_subscription_from_end_time():
+    user, pu = create_partner_linked_user()
+    sub_end = user.get_active_subscription_end(include_partner_subscription=False)
+    assert sub_end is None
+    _dispatch_plan_change_for_user(user, pu)
+    plan_change = _get_plan_change_event(on_memory_dispatcher.memory[0], user, pu)
+    assert plan_change.plan_end_time == 0
