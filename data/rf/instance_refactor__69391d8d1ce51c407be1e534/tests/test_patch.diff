+func TestNewFilteredRepoCache(t *testing.T) {
+	s := &Source{}
+	s.log = logr.Discard()
+
+	c := memory.New[string]()
+	frc := s.newFilteredRepoCache(c, []string{"include-*"}, []string{"exclude-*"})
+
+	frc.Set("include-repo", "include-repo")
+	frc.Set("exclude-repo", "exclude-repo")
+	frc.Set("other-repo", "other-repo")
+
+	assert.True(t, frc.Exists("include-repo"))
+	assert.False(t, frc.Exists("exclude-repo"))
+	assert.False(t, frc.Exists("other-repo"))
+	assert.Equal(t, 1, frc.Count())
+
+	v, ok := frc.Get("include-repo")
+	assert.True(t, ok)
+	assert.Equal(t, "include-repo", v)
+}
diff --git a/pkg/cache/memory/memory_generic_test.go b/pkg/cache/memory/memory_generic_test.go
