+static int DetectEngineAnalyzerTest03(void)
+{
+    const char *conf =
+        "%YAML 1.1\n"
+        "---\n"
+        "engine-analysis:\n"
+        "  rules-fast-pattern: no\n"
+        "  rules: no\n";
+
+    FAIL_IF(EngineAnalysisInitYamlConf(conf) == -1);
+
+    DetectEngineCtx *de_ctx = DetectEngineCtxInit();
+    FAIL_IF_NULL(de_ctx);
+
+    bool fp_analysis = true;
+    bool rule_analysis = true;
+    SetupEngineAnalysis(de_ctx, &fp_analysis, &rule_analysis);
+
+    FAIL_IF(fp_analysis);
+    FAIL_IF(rule_analysis);
+
+    DetectEngineCtxFree(de_ctx);
+    EngineAnalysisDeInitYamlConf();
+    PASS;
+}
