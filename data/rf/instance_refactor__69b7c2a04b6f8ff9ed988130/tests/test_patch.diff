+static int EngineAnalysisInitYamlConf(const char *conf)
+{
+    ConfCreateContextBackup();
+    ConfInit();
+    return ConfYamlLoadString(conf, strlen(conf));
+}
+
+static void EngineAnalysisDeInitYamlConf(void)
+{
+    ConfDeInit();
+    ConfRestoreContextBackup();
+}
