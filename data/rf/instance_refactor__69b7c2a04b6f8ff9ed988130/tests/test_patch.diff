+/**
+ * \test Verify DetectEngineCtx has the ea field and it starts NULL.
+ */
+static int DetectEngineAnalyzerTest01(void)
+{
+    DetectEngineCtx *de_ctx = DetectEngineCtxInit();
+    FAIL_IF_NULL(de_ctx);
+
+    FAIL_IF_NOT_NULL(de_ctx->ea);
+
+    DetectEngineCtxFree(de_ctx);
+    PASS;
+}
+
+/**
+ * \test Verify DetectEngineCtx has the relocated hash tables and
+ *       the new pcre fields for classification and reference config parsing.
