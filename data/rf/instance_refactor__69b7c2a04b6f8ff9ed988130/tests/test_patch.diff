+static int DetectEngineAnalyzerTest02(void)
+{
+    DetectEngineCtx *de_ctx = DetectEngineCtxInit();
+    FAIL_IF_NULL(de_ctx);
+
+    FAIL_IF_NULL(de_ctx->class_conf_ht);
+    FAIL_IF_NULL(de_ctx->reference_conf_ht);
+
+    FAIL_IF_NOT_NULL(de_ctx->class_conf_regex);
+    FAIL_IF_NOT_NULL(de_ctx->class_conf_regex_study);
+    FAIL_IF_NOT_NULL(de_ctx->reference_conf_regex);
+    FAIL_IF_NOT_NULL(de_ctx->reference_conf_regex_study);
+
+    DetectEngineCtxFree(de_ctx);
+    PASS;
+}
